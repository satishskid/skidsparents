---
export const prerender = true
import LeadCaptureForm from '../components/LeadCaptureForm'
import UtmPreserver from '../components/UtmPreserver.astro'
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>SKIDS — Proactive Pediatric Health for Indian Families</title>
  <meta name="description" content="Indian pediatrics is reactive. SKIDS is proactive. Free PHR, AI health companion, and specialist services for your child aged 0–16." />
  <link rel="icon" href="https://parent.skids.clinic/favicon.svg" type="image/svg+xml" />
  <style>
    @import "tailwindcss";
    body { font-family: system-ui, sans-serif; }
  </style>
</head>
<body class="bg-white text-gray-900">
  <UtmPreserver />

  <!-- Nav -->
  <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100 px-4 py-3 flex items-center justify-between">
    <a href="/" class="font-bold text-blue-600 text-lg tracking-tight">SKIDS</a>
    <div class="flex items-center gap-4 text-sm">
      <a href="/for-parents" class="text-gray-600 hover:text-gray-900">For Parents</a>
      <a href="/for-doctors" class="text-gray-600 hover:text-gray-900">For Doctors</a>
      <a href="/blog" class="text-gray-600 hover:text-gray-900">Blog</a>
      <a
        href={`https://parent.skids.clinic?utm_source=skids_clinic&utm_campaign=skids_parent_cta`}
        class="px-4 py-2 bg-blue-600 text-white rounded-full text-sm font-medium hover:bg-blue-700"
      >
        Open App
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="px-4 pt-16 pb-12 max-w-5xl mx-auto text-center">
    <div class="inline-block px-3 py-1 bg-blue-50 text-blue-700 rounded-full text-xs font-medium mb-4">
      For Indian parents of children 0–16 years
    </div>
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-4">
      Indian pediatrics is reactive.<br />
      <span class="text-blue-600">SKIDS is proactive.</span>
    </h1>
    <p class="text-lg text-gray-500 max-w-2xl mx-auto mb-8">
      A complete health record, AI companion, and specialist services — built for how Indian families actually raise children.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href={`/for-parents?utm_source=skids_clinic&utm_campaign=skids_parent_cta`}
        class="px-6 py-3 bg-blue-600 text-white rounded-xl font-semibold hover:bg-blue-700 transition-colors"
      >
        I'm a Parent
      </a>
      <a
        href={`/for-doctors?utm_source=skids_clinic&utm_campaign=skids_provider_cta`}
        class="px-6 py-3 border border-gray-300 text-gray-700 rounded-xl font-semibold hover:bg-gray-50 transition-colors"
      >
        I'm a Doctor
      </a>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="bg-gray-50 px-4 py-14">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-center mb-10">The SKIDS difference</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { emoji: '📋', title: 'One health record', body: 'Growth, milestones, vaccinations, observations — all in one place, from birth to 16.' },
          { emoji: '🤖', title: 'AI that knows your child', body: 'Dr. SKIDS reads your child\'s full PHR before answering. Not generic advice — your child\'s advice.' },
          { emoji: '🏥', title: 'Specialists when you need them', body: 'Vision, nutrition, therapy, teleconsult — booked in minutes, connected to your child\'s record.' },
        ].map(card => (
          <div class="bg-white rounded-2xl p-6 shadow-sm">
            <div class="text-3xl mb-3">{card.emoji}</div>
            <h3 class="font-semibold text-gray-900 mb-2">{card.title}</h3>
            <p class="text-sm text-gray-500">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Content teaser -->
  <section class="px-4 py-14 max-w-4xl mx-auto">
    <h2 class="text-2xl font-bold text-center mb-2">Explore your child's world</h2>
    <p class="text-center text-gray-500 text-sm mb-8">16 organ discovery modules. 6 H.A.B.I.T.S. frameworks. Hundreds of articles.</p>
    <div class="flex flex-wrap justify-center gap-3">
      {['🧠 Brain', '👁️ Vision', '👂 Hearing', '🍎 Nutrition', '🏃 Movement', '😴 Sleep'].map(item => (
        <a
          href={`https://parent.skids.clinic/discover?utm_source=skids_clinic&utm_campaign=skids_parent_cta`}
          class="px-4 py-2 bg-gray-100 rounded-full text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700 transition-colors"
        >
          {item}
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-blue-600 px-4 py-14 text-white text-center">
    <h2 class="text-2xl font-bold mb-2">Start free today</h2>
    <p class="text-blue-100 mb-6 text-sm">No app download. Works on any phone.</p>
    <a
      href={`https://parent.skids.clinic?utm_source=skids_clinic&utm_campaign=skids_parent_cta`}
      class="inline-block px-8 py-3 bg-white text-blue-600 rounded-xl font-semibold hover:bg-blue-50 transition-colors"
    >
      Open SKIDS Parent
    </a>
  </section>

  <!-- Footer -->
  <footer class="px-4 py-8 text-center text-xs text-gray-400 border-t border-gray-100">
    <p>© {new Date().getFullYear()} SKIDS Health Technologies Pvt. Ltd. · Bengaluru, India</p>
    <p class="mt-1">
      <a href="/blog" class="hover:text-gray-600">Blog</a> ·
      <a href="/organs" class="hover:text-gray-600 ml-2">Organ Discovery</a> ·
      <a href="/habits" class="hover:text-gray-600 ml-2">H.A.B.I.T.S.</a> ·
      <a href="https://parent.skids.clinic/provider/signup" class="hover:text-gray-600 ml-2">For Doctors</a>
    </p>
  </footer>

</body>
</html>
