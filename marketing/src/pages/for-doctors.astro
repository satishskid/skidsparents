---
export const prerender = true
import LeadCaptureForm from '../components/LeadCaptureForm'
import UtmPreserver from '../components/UtmPreserver.astro'
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>SKIDS for Doctors — Join the Pediatric Specialist Network</title>
  <meta name="description" content="Reach verified patients, set your own schedule, and consult with full PHR context. Join SKIDS as a pediatric specialist." />
  <link rel="icon" href="https://parent.skids.clinic/favicon.svg" type="image/svg+xml" />
  <style>
    @import "tailwindcss";
    body { font-family: system-ui, sans-serif; }
  </style>
</head>
<body class="bg-white text-gray-900">
  <UtmPreserver />

  <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100 px-4 py-3 flex items-center justify-between">
    <a href="/" class="font-bold text-blue-600 text-lg">SKIDS</a>
    <a href="/for-parents" class="text-sm text-gray-500 hover:text-gray-800">For Parents →</a>
  </nav>

  <!-- Hero -->
  <section class="px-4 pt-14 pb-10 max-w-4xl mx-auto">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <div class="inline-block px-3 py-1 bg-green-50 text-green-700 rounded-full text-xs font-medium mb-4">
          For pediatric specialists
        </div>
        <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-4">
          Consult smarter.<br />
          <span class="text-green-600">Earn more.</span>
        </h1>
        <p class="text-gray-500 mb-6">
          Every consultation comes with the child's full health record — growth history, milestones, vaccinations, and parent observations. No more starting from scratch.
        </p>
        <ul class="space-y-2 text-sm text-gray-600 mb-6">
          {[
            '📋 Full PHR context before every session',
            '🤖 AI clinical brief — DDx, red flags, vaccination gaps',
            '📅 Set your own availability and fees',
            '💊 Digital prescription with WhatsApp delivery',
            '💰 Transparent earnings — set your rate, we take a small commission',
            '🔒 Verified patients only',
          ].map(item => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
      <div class="bg-gray-50 rounded-2xl p-6 shadow-sm">
        <LeadCaptureForm
          variant="provider"
          heading="Apply to join SKIDS"
          subheading="We'll review your application and get back within 48 hours."
          client:load
        />
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-gray-50 px-4 py-12">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-center mb-8">How it works</h2>
      <div class="space-y-4">
        {[
          { step: '1', title: 'Apply and get verified', body: 'Submit your medical registration number and credentials. We verify within 48 hours.' },
          { step: '2', title: 'Set your schedule', body: 'Add recurring or one-off slots. Parents book directly — no back-and-forth.' },
          { step: '3', title: 'Consult with full context', body: 'AI brief ready before you join. PHR, milestones, vaccinations — all in the session room.' },
          { step: '4', title: 'Send prescription digitally', body: 'Medications, nutrition, behavioural guidance, follow-up — delivered to parent via WhatsApp.' },
        ].map(s => (
          <div class="flex gap-4 bg-white rounded-xl p-4 shadow-sm">
            <div class="w-8 h-8 rounded-full bg-green-600 text-white flex items-center justify-center text-sm font-bold flex-shrink-0">
              {s.step}
            </div>
            <div>
              <div class="font-medium text-gray-800 text-sm">{s.title}</div>
              <div class="text-xs text-gray-500 mt-0.5">{s.body}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Earnings model -->
  <section class="px-4 py-12 max-w-3xl mx-auto">
    <h2 class="text-2xl font-bold text-center mb-2">Transparent earnings</h2>
    <p class="text-center text-gray-500 text-sm mb-8">You set your consultation fee. SKIDS takes a platform commission.</p>
    <div class="bg-blue-50 rounded-2xl p-6 text-center">
      <p class="text-sm text-gray-600 mb-2">Example: ₹800 consultation</p>
      <div class="flex justify-center gap-8 text-sm">
        <div>
          <div class="text-2xl font-bold text-green-700">₹680</div>
          <div class="text-xs text-gray-500">Your payout</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-gray-400">₹120</div>
          <div class="text-xs text-gray-500">Platform fee (15%)</div>
        </div>
      </div>
      <p class="text-xs text-gray-400 mt-4">Commission rates vary. Discussed during onboarding.</p>
    </div>
  </section>

  <footer class="px-4 py-6 text-center text-xs text-gray-400 border-t border-gray-100">
    <a href="/">← Back to SKIDS</a>
  </footer>

</body>
</html>
