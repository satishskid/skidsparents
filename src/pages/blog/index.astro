---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import ChatWidget from '@/components/chat/ChatWidget'
import BlogSearch from '@/components/blog/BlogSearch'

export const prerender = false

// Search query from ?q= parameter
const searchQuery = Astro.url.searchParams.get('q')?.trim().toLowerCase() || ''

// Fetch blogs from SKIDS API
let blogs: any[] = []
let categories: string[] = []
try {
  const res = await fetch('https://9vhd0onw23.execute-api.ap-south-1.amazonaws.com/published-blogs')
  if (res.ok) {
    let allBlogs = (await res.json()) as any[]
    // Sort by createdAt (latest first)
    allBlogs.sort((a: any, b: any) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
    // Extract unique categories
    const catSet = new Set<string>()
    allBlogs.forEach((b: any) => {
      if (b.category) catSet.add(b.category)
    })
    categories = Array.from(catSet).sort()
    // Filter by search query if present
    if (searchQuery) {
      blogs = allBlogs.filter((b: any) => {
        const title = (b.title || '').toLowerCase()
        const category = (b.category || '').toLowerCase()
        const summary = (b.summary || '').toLowerCase()
        const content = (b.content || '').toLowerCase()
        return title.includes(searchQuery) || category.includes(searchQuery) || summary.includes(searchQuery) || content.includes(searchQuery)
      })
    } else {
      blogs = allBlogs
    }
  }
} catch {
  blogs = []
}

const categoryColors: Record<string, string> = {
  'Mental Health': 'bg-purple-100 text-purple-700',
  'Parental Guidance': 'bg-pink-100 text-pink-700',
  'Physical Health': 'bg-green-100 text-green-700',
  'Nutrition & Diet': 'bg-orange-100 text-orange-700',
  'Kids Vision': 'bg-amber-100 text-amber-700',
  'Wellness': 'bg-teal-100 text-teal-700',
  'Child Development': 'bg-blue-100 text-blue-700',
}
---

<BaseLayout
  title="Health Blog"
  description="Daily evidence-based articles on child health, nutrition, development, and parenting. Written by pediatricians and child health experts."
  keywords={['child health blog', 'parenting articles', 'pediatric health', 'child development', 'nutrition', 'Indian parents', 'SKIDS', 'evidence-based parenting']}
  ogType="website"
>
  <Navbar />

  <main class="min-h-screen section-warm">
    <!-- Header -->
    <section class="bg-white border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
        <div class="max-w-2xl">
          <span class="text-xs font-semibold text-green-600 uppercase tracking-wider">Learn</span>
          {searchQuery ? (
            <div>
              <h1 class="mt-2 text-2xl sm:text-3xl font-display font-bold text-gray-900">
                Results for "{searchQuery}"
              </h1>
              <p class="mt-3 text-sm text-gray-500">
                {blogs.length} article{blogs.length !== 1 ? 's' : ''} found.
                <a href="/blog" class="text-green-600 font-medium hover:underline ml-1">Clear search</a>
              </p>
            </div>
          ) : (
            <div>
              <h1 class="mt-2 text-2xl sm:text-3xl font-display font-bold text-gray-900">
                Today's parenting wisdom
              </h1>
              <p class="mt-3 text-sm text-gray-500">
                Daily insights from pediatricians, nutritionists, and child development experts. Evidence-based, empathy-driven.
              </p>
            </div>
          )}

          <!-- Semantic search (AI-powered via Vectorize RAG) -->
          <div class="mt-5">
            <BlogSearch client:load />
          </div>
        </div>

        <!-- Category Filters -->
        {categories.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2" id="category-filters">
            <button
              data-category="all"
              class="category-btn px-3.5 py-1.5 rounded-full text-sm font-medium bg-gray-900 text-white transition-colors"
            >
              All
            </button>
            {categories.map((cat) => (
              <button
                data-category={cat}
                class="category-btn px-3.5 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors"
              >
                {cat}
              </button>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Blog Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      {blogs.length === 0 ? (
        <div class="text-center py-20">
          <div class="text-4xl mb-4">📝</div>
          <h2 class="text-xl font-display font-bold text-gray-900">Articles loading...</h2>
          <p class="mt-2 text-gray-500">Check back soon for the latest health insights.</p>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5" id="blog-grid">
          {blogs.map((blog: any) => {
            const blogDate = blog.createdAt
              ? new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
              : undefined
            return (
              <article
                class="blog-card card-hover group block rounded-2xl overflow-hidden bg-white border border-gray-100 shadow-sm"
                data-category={blog.category || ''}
              >
                <a href={`/blog/${blog.blogId}`}>
                  {blog.thumbnail && (
                    <div class="aspect-[16/9] overflow-hidden bg-gray-100">
                      <img
                        src={blog.thumbnail}
                        alt={blog.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="p-4">
                    <!-- Category -->
                    {blog.category && (
                      <span class={`text-[10px] font-semibold px-2.5 py-0.5 rounded-full ${categoryColors[blog.category] || 'bg-gray-100 text-gray-600'} uppercase tracking-wider`}>
                        {blog.category}
                      </span>
                    )}

                    <h2 class="mt-2 text-sm font-display font-bold text-gray-900 group-hover:text-green-600 transition-colors line-clamp-2">
                      {blog.title}
                    </h2>

                    <div class="mt-3 flex items-center gap-1.5 text-xs text-gray-400">
                      {blog.author && <span>{blog.author}</span>}
                      {blog.author && blogDate && <span>·</span>}
                      {blogDate && <time>{blogDate}</time>}
                    </div>
                  </div>
                </a>
              </article>
            )
          })}
        </div>
      )}
    </section>
  </main>

  <Footer />
  <div class="h-16 md:hidden"></div>
  <ChatWidget client:idle />
  <MobileTabBar />
</BaseLayout>

<script>
  // Client-side category filtering
  const buttons = document.querySelectorAll('.category-btn')
  const cards = document.querySelectorAll('.blog-card')

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = (btn as HTMLElement).dataset.category

      // Update active button
      buttons.forEach((b) => {
        b.classList.remove('bg-gray-900', 'text-white')
        b.classList.add('bg-gray-100', 'text-gray-600')
      })
      btn.classList.remove('bg-gray-100', 'text-gray-600')
      btn.classList.add('bg-gray-900', 'text-white')

      // Filter cards
      cards.forEach((card) => {
        const cardCategory = (card as HTMLElement).dataset.category || ''
        if (category === 'all' || cardCategory === category) {
          ;(card as HTMLElement).style.display = ''
        } else {
          ;(card as HTMLElement).style.display = 'none'
        }
      })
    })
  })
</script>
