---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import ChatWidget from '@/components/chat/ChatWidget'
import { SOCIAL, BRAND, whatsappShareUrl, twitterShareUrl, facebookShareUrl } from '@/lib/config/social'
import { getOrganForCategory } from '@/lib/content/organs'

export const prerender = false  // SSR — dynamic route

const { slug } = Astro.params

// Fetch all blogs and find matching one
let blog: any = null
let relatedBlogs: any[] = []
try {
  const res = await fetch('https://9vhd0onw23.execute-api.ap-south-1.amazonaws.com/published-blogs')
  if (res.ok) {
    const blogs = (await res.json()) as any[]
    blog = blogs.find((b: any) => b.blogId === slug)
    if (blog) {
      // Get related blogs from same category (up to 3)
      relatedBlogs = blogs
        .filter((b: any) => b.blogId !== slug && b.category === blog.category)
        .sort((a: any, b: any) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
        .slice(0, 3)
    }
  }
} catch {
  // Fallback
}

if (!blog) {
  return Astro.redirect('/blog')
}

// Format date
const blogDate = blog.createdAt
  ? new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : ''
const isoDate = blog.createdAt ? new Date(blog.createdAt).toISOString() : ''

// Generate SEO keywords from blog content
const seoKeywords = [
  blog.category || 'child health',
  'parenting',
  'child development',
  'pediatric health',
  'Indian parents',
  'SKIDS',
  ...(blog.title ? blog.title.toLowerCase().split(' ').filter((w: string) => w.length > 4).slice(0, 3) : [])
]

// Linked organ
const linkedOrgan = getOrganForCategory(blog.category || '')

// Share URLs
const pageUrl = `${BRAND.siteUrl}/blog/${blog.blogId}`
const shareText = `${blog.title} — SKIDS Parent`
const waShare = whatsappShareUrl(shareText, pageUrl)
const twShare = twitterShareUrl(blog.title, pageUrl)
const fbShare = facebookShareUrl(pageUrl)

// Category colors
const categoryColors: Record<string, string> = {
  'Mental Health': 'bg-purple-100 text-purple-700',
  'Parental Guidance': 'bg-pink-100 text-pink-700',
  'Physical Health': 'bg-green-100 text-green-700',
  'Nutrition & Diet': 'bg-orange-100 text-orange-700',
  'Kids Vision': 'bg-amber-100 text-amber-700',
  'Wellness': 'bg-teal-100 text-teal-700',
  'Child Development': 'bg-blue-100 text-blue-700',
}
const catColor = categoryColors[blog.category] || 'bg-gray-100 text-gray-600'
---

<BaseLayout
  title={blog.title}
  description={`${blog.title} — Expert insights on ${blog.category || 'child health'} from SKIDS Parent. Evidence-based guidance for modern parents.`}
  keywords={seoKeywords}
  ogImage={blog.thumbnail}
  ogType="article"
  article={{
    headline: blog.title,
    author: blog.author || 'SKIDS Team',
    datePublished: isoDate,
    image: blog.thumbnail,
    category: blog.category || 'Health',
    description: `Expert insights on ${blog.category || 'child health'} from SKIDS Parent.`,
  }}
>
  <Navbar />

  <main class="min-h-screen">
    <!-- Hero Image -->
    {blog.thumbnail && (
      <div class="relative w-full h-[50vh] sm:h-[55vh] overflow-hidden">
        <img
          src={blog.thumbnail}
          alt={blog.title}
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />

        <!-- Back button -->
        <a
          href="/blog"
          class="absolute top-4 left-4 z-10 flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-black/30 backdrop-blur-sm text-white text-xs font-medium hover:bg-black/50 transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          All Articles
        </a>
      </div>
    )}

    <!-- Article Content -->
    <article class="max-w-2xl mx-auto px-4 sm:px-6 -mt-20 relative z-10">
      <!-- Card -->
      <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-6 sm:p-8">
        <!-- Category -->
        {blog.category && (
          <span class={`inline-block text-[10px] font-semibold px-2.5 py-1 rounded-full ${catColor} uppercase tracking-wider mb-4`}>
            {blog.category}
          </span>
        )}

        <!-- Title -->
        <h1 class="text-2xl sm:text-3xl font-display font-bold text-gray-900 leading-tight">
          {blog.title}
        </h1>

        <!-- Author & Date -->
        <div class="mt-4 flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center text-white text-xs font-bold">
            {(blog.author || 'S')[0].toUpperCase()}
          </div>
          <div>
            <div class="text-sm font-semibold text-gray-900">{blog.author || 'SKIDS Team'}</div>
            {blogDate && <div class="text-xs text-gray-400">{blogDate}</div>}
          </div>
        </div>

        <!-- Share Buttons -->
        <div class="mt-6 flex items-center gap-2">
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider mr-1">Share</span>
          <a href={waShare} target="_blank" rel="noopener" class="w-9 h-9 rounded-full bg-green-50 flex items-center justify-center text-green-600 hover:bg-green-100 transition-colors" aria-label="Share on WhatsApp">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
          <a href={twShare} target="_blank" rel="noopener" class="w-9 h-9 rounded-full bg-gray-50 flex items-center justify-center text-gray-600 hover:bg-gray-100 transition-colors" aria-label="Share on Twitter">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={fbShare} target="_blank" rel="noopener" class="w-9 h-9 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 hover:bg-blue-100 transition-colors" aria-label="Share on Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <button
            class="copy-link-btn w-9 h-9 rounded-full bg-gray-50 flex items-center justify-center text-gray-600 hover:bg-gray-100 transition-colors"
            data-url={pageUrl}
            aria-label="Copy link"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
            </svg>
          </button>
        </div>

        <!-- Article body placeholder -->
        <div class="mt-8 prose prose-green prose-sm max-w-none">
          <div class="p-6 rounded-xl bg-green-50/50 border border-green-100 text-center">
            <p class="text-sm text-gray-600 mb-4">
              This article is available to read in full. Tap below to continue reading.
            </p>
            <a
              href={`https://skids.clinic/blog/${blog.blogId}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-green-600 text-white font-semibold text-sm hover:bg-green-700 transition-colors"
            >
              Read Full Article
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Linked Organ (contextual) -->
        {linkedOrgan && (
          <div class="mt-8 p-4 rounded-xl bg-purple-50/50 border border-purple-100">
            <div class="flex items-center gap-3">
              <span class="text-3xl">{linkedOrgan.emoji}</span>
              <div>
                <div class="text-[10px] font-bold text-purple-600 uppercase tracking-wider">Related Organ</div>
                <div class="text-sm font-semibold text-gray-900">{linkedOrgan.name}</div>
                <p class="text-xs text-gray-500 mt-0.5">{linkedOrgan.wonderFact}</p>
              </div>
            </div>
            <a href={`/discover/${linkedOrgan.slug}`} class="mt-2 inline-flex items-center gap-1 text-xs font-semibold text-purple-600 hover:text-purple-700">
              Explore {linkedOrgan.name} →
            </a>
          </div>
        )}

        <!-- Ask Dr. SKIDS about this -->
        <div class="mt-6">
          <button
            class="quick-q-pill w-full text-left p-4 rounded-xl bg-gradient-to-r from-green-600 to-emerald-600 text-white hover:from-green-700 hover:to-emerald-700 transition-all"
            data-question={`Tell me more about ${blog.category?.toLowerCase() || 'health'} and how it affects my child's development`}
          >
            <div class="flex items-center gap-3">
              <span class="text-2xl">🩺</span>
              <div>
                <div class="text-xs font-bold uppercase tracking-wider text-white/70">Ask Dr. SKIDS</div>
                <div class="text-sm font-semibold">How does this affect my child?</div>
              </div>
              <svg class="w-5 h-5 ml-auto text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </div>
          </button>
        </div>
      </div>

      <!-- Related Articles -->
      {relatedBlogs.length > 0 && (
        <div class="mt-8 mb-8">
          <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">More in {blog.category}</h2>
          <div class="space-y-3">
            {relatedBlogs.map((rb: any) => (
              <a href={`/blog/${rb.blogId}`} class="flex gap-3 p-3 rounded-xl bg-white border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all group">
                {rb.thumbnail && (
                  <img src={rb.thumbnail} alt="" class="w-16 h-16 rounded-lg object-cover flex-shrink-0" loading="lazy" />
                )}
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-semibold text-gray-900 line-clamp-2 group-hover:text-green-600 transition-colors">{rb.title}</h3>
                  <div class="text-xs text-gray-400 mt-1">{rb.author || 'SKIDS Team'}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </article>
  </main>

  <Footer />
  <div class="h-16 md:hidden"></div>
  <ChatWidget client:idle />
  <MobileTabBar />
</BaseLayout>

<script define:vars={{ blogId: blog.blogId, blogTitle: blog.title, blogCategory: blog.category }}>
  // Analytics: track content_view with duration
  const _viewStart = Date.now()

  function _trackBlogView(durationSeconds) {
    if (typeof window !== 'undefined' && (window as any).skidsTrack) {
      ;(window as any).skidsTrack('content_view', {
        type: 'blog',
        slug: blogId,
        title: blogTitle,
        category: blogCategory,
        duration_seconds: durationSeconds,
      })
    }
    // Also POST to engagement API (fire-and-forget, best effort)
    fetch('/api/engagement/track', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contentType: 'blog',
        contentId: blogId,
        action: 'view',
        durationSeconds,
      }),
    }).catch(() => {})
  }

  // Track on page hide / unload
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') {
      const duration = Math.round((Date.now() - _viewStart) / 1000)
      _trackBlogView(duration)
    }
  })
  window.addEventListener('pagehide', () => {
    const duration = Math.round((Date.now() - _viewStart) / 1000)
    _trackBlogView(duration)
  })
</script>

<script>
  // Copy link button
  document.querySelectorAll('.copy-link-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = (btn as HTMLElement).dataset.url || window.location.href
      try {
        await navigator.clipboard.writeText(url)
        // Visual feedback
        const svg = btn.querySelector('svg')
        if (svg) {
          svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />'
          setTimeout(() => {
            svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />'
          }, 2000)
        }
      } catch {
        // Fallback
        prompt('Copy this link:', url)
      }
    })
  })

  // Wire Dr. SKIDS button
  document.querySelectorAll('.quick-q-pill').forEach((pill) => {
    pill.addEventListener('click', () => {
      const question = (pill as HTMLElement).dataset.question || ''
      window.dispatchEvent(new CustomEvent('open-dr-skids', { detail: { question } }))
    })
  })
</script>
