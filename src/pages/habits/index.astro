---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import { HABITS } from '@/lib/content/habits'

export const prerender = true

/* Color mapping per HABITS letter */
const letterColors: Record<string, { accent: string }> = {
  H: { accent: 'bg-green-600' },
  A: { accent: 'bg-orange-500' },
  B: { accent: 'bg-purple-600' },
  I: { accent: 'bg-blue-600' },
  T: { accent: 'bg-amber-500' },
  S: { accent: 'bg-indigo-600' },
}

/* All 6 workshop programs — acronyms expanded for reinforced learning */
const workshops = [
  {
    id: 'healthy-habits',
    title: 'Healthy Habits',
    subtitle: 'Smart & Super Kids App',
    framework: 'H.A.B.I.T.S.',
    letters: [
      { letter: 'H', word: 'Healthy Eating' },
      { letter: 'A', word: 'Active Movement' },
      { letter: 'B', word: 'Balanced Stress' },
      { letter: 'I', word: 'Inner Coaching' },
      { letter: 'T', word: 'Timekeepers' },
      { letter: 'S', word: 'Sufficient Sleep' },
    ],
    description: 'Build lifelong healthy habits through 6 daily practices — nutrition, movement, stress, mindset, routine, and sleep.',
    gradient: 'from-green-500 to-emerald-600',
    duration: '45 mins',
    category: 'School',
  },
  {
    id: 'digiparenting',
    title: 'DigiParenting',
    subtitle: 'The Neuroscience of Connection',
    framework: 'A.B.C.D.E.',
    letters: [
      { letter: 'A', word: 'Acknowledge' },
      { letter: 'B', word: 'Brainstorm' },
      { letter: 'C', word: 'Choose' },
      { letter: 'D', word: 'Do It' },
      { letter: 'E', word: 'Evaluate' },
    ],
    description: 'A 5-step method for resolving conflict with teenagers using neuroscience-backed communication.',
    gradient: 'from-indigo-500 to-purple-600',
    duration: '60 mins',
    category: 'Clinic',
  },
  {
    id: 'fueling-potential',
    title: 'Fueling Potential',
    subtitle: 'The Science of Smart Eating',
    framework: 'F.R.E.S.H.',
    letters: [
      { letter: 'F', word: 'Fiber' },
      { letter: 'R', word: 'Rainbow Foods' },
      { letter: 'E', word: 'Energy' },
      { letter: 'S', word: 'Sugar Awareness' },
      { letter: 'H', word: 'Hydration' },
    ],
    description: 'The 5 pillars of pediatric nutrition — what to eat, what to avoid, and why it matters for the growing brain.',
    gradient: 'from-lime-500 to-green-600',
    duration: '50 mins',
    category: 'Clinic',
  },
  {
    id: 'screen-smart',
    title: 'Screen Smart',
    subtitle: 'Mastering the Machine in Your Pocket',
    framework: 'S.M.A.R.T.',
    letters: [
      { letter: 'S', word: 'Sleep Sanctuary' },
      { letter: 'M', word: 'Move First' },
      { letter: 'A', word: 'Ask Why' },
      { letter: 'R', word: 'Real Connection' },
      { letter: 'T', word: 'Turn Off Pings' },
    ],
    description: 'A digital wellness method — protect sleep, prioritize movement, and build real-world connection over screen time.',
    gradient: 'from-sky-500 to-blue-600',
    duration: '55 mins',
    category: 'Clinic',
  },
  {
    id: 'life-lab',
    title: 'Life Lab',
    subtitle: 'The Human Manual',
    framework: '4 Modules',
    letters: [
      { letter: '1', word: 'The Plastic Brain' },
      { letter: '2', word: 'Habit Architecture' },
      { letter: '3', word: 'Emotional Agility' },
      { letter: '4', word: 'Values & Purpose' },
    ],
    description: 'Essential life skills for grades 6-12 — neuroplasticity, habit architecture, emotional agility, and values-based living.',
    gradient: 'from-teal-500 to-cyan-600',
    duration: '60 mins',
    category: 'School',
  },
  {
    id: 'innovation-engine',
    title: 'Innovation Engine',
    subtitle: 'The F.I.R.E. Protocol',
    framework: 'F.I.R.E.',
    letters: [
      { letter: 'F', word: 'Flow' },
      { letter: 'I', word: 'Iterate' },
      { letter: 'R', word: 'Remix' },
      { letter: 'E', word: 'Expand' },
    ],
    description: 'Become a future builder using creativity science — from King to Dyson, Gutenberg to Da Vinci.',
    gradient: 'from-rose-500 to-pink-600',
    duration: '50 mins',
    category: 'School',
  },
]

const clinicWorkshops = workshops.filter(w => w.category === 'Clinic')
const schoolWorkshops = workshops.filter(w => w.category === 'School')
---

<BaseLayout
  title="Practice — Daily Habits & Workshops | SKIDS"
  description="Six daily habits backed by neuroscience, plus interactive workshop programs for parents and students. H.A.B.I.T.S., DigiParenting, Fueling Potential, Screen Smart, Life Lab, and Innovation Engine."
>
  <Navbar />

  <main class="min-h-screen">

    <!-- ═══════════════════════════════════════════════════
         HERO — Emotional, brand-led.
         ═══════════════════════════════════════════════════ -->
    <section class="relative overflow-hidden bg-gray-950">
      <div class="absolute inset-0 bg-gradient-to-br from-amber-900 via-gray-950 to-orange-900"></div>
      <div class="relative max-w-4xl mx-auto px-5 sm:px-8 py-20 sm:py-28 text-center">
        <p class="reveal text-amber-400 text-xs font-semibold uppercase tracking-widest mb-4">Practice</p>
        <h1 class="reveal font-serif text-[clamp(2rem,5vw,3.5rem)] leading-[1.08] tracking-tight text-white">
          Knowing isn't enough.<br class="hidden sm:block" />
          These six habits make it real.
        </h1>
        <p class="reveal reveal-delay-1 mt-5 text-lg text-white/50 max-w-xl mx-auto leading-relaxed">
          Nutrition. Movement. Stress. Mindset. Routine. Sleep.
          Practiced every day, from birth to sixteen, they shape everything
          about who your child becomes.
        </p>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         H.A.B.I.T.S. — The 6 daily habits
         ═══════════════════════════════════════════════════ -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <div class="reveal mb-10">
        <h2 class="text-2xl font-serif text-gray-900 tracking-tight">H.A.B.I.T.S. &mdash; Daily Habits</h2>
        <p class="mt-1 text-gray-500">6 evidence-based daily practices for every age, from birth to 16</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {HABITS.map((habit) => {
          const colors = letterColors[habit.letter] || letterColors.H
          return (
            <a href={`/habits/${habit.key}`} class="reveal group card-hover block p-6 rounded-2xl bg-white border border-gray-100 shadow-sm">
              <div class="flex items-start gap-4">
                <div class={`w-12 h-12 rounded-xl ${colors.accent} flex items-center justify-center text-white text-xl font-bold shadow-sm flex-shrink-0`}>
                  {habit.letter}
                </div>
                <div class="flex-1">
                  <h3 class="font-display font-bold text-gray-900 group-hover:text-green-600 transition-colors">
                    {habit.name}
                  </h3>
                  <p class="mt-1 text-sm text-gray-500">{habit.tagline}</p>
                  <div class="mt-3 flex items-center gap-3 text-xs text-gray-400">
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      Ages 0-16
                    </span>
                    <span class="flex items-center gap-1 text-green-500">
                      Explore &rarr;
                    </span>
                  </div>
                </div>
              </div>
            </a>
          )
        })}
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         WORKSHOPS — For Parents (Clinic)
         ═══════════════════════════════════════════════════ -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="reveal mb-10">
        <h2 class="text-2xl font-serif text-gray-900 tracking-tight">For Parents</h2>
        <p class="mt-1 text-gray-500">Interactive workshops with companion apps for daily practice</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {clinicWorkshops.map((w) => (
          <a href={`/workshops/${w.id}.html`} class="reveal group card-hover block rounded-2xl bg-white border border-gray-100 shadow-sm overflow-hidden">
            <div class={`bg-gradient-to-r ${w.gradient} px-5 py-5`}>
              <div class="flex flex-wrap gap-x-4 gap-y-1">
                {w.letters.map((l) => (
                  <span class="text-white/90 text-xs font-medium">
                    <span class="text-white font-bold text-sm">{l.letter}</span> {l.word}
                  </span>
                ))}
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-display font-bold text-gray-900 group-hover:text-green-600 transition-colors">
                {w.title}
              </h3>
              <p class="text-sm text-gray-500 font-medium mb-2">{w.subtitle}</p>
              <p class="text-sm text-gray-500 line-clamp-2">{w.description}</p>
              <div class="mt-3 flex items-center justify-between text-xs text-gray-400">
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {w.duration}
                </span>
                <span class="text-green-500">Start &rarr;</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         WORKSHOPS — For Students (School)
         ═══════════════════════════════════════════════════ -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <div class="reveal mb-10">
        <h2 class="text-2xl font-serif text-gray-900 tracking-tight">For Students</h2>
        <p class="mt-1 text-gray-500">Programs designed for grades 6-12 &mdash; learn how your brain and body work</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {schoolWorkshops.map((w) => (
          <a href={`/workshops/${w.id}.html`} class="reveal group card-hover block rounded-2xl bg-white border border-gray-100 shadow-sm overflow-hidden">
            <div class={`bg-gradient-to-r ${w.gradient} px-5 py-5`}>
              <div class="flex flex-wrap gap-x-4 gap-y-1">
                {w.letters.map((l) => (
                  <span class="text-white/90 text-xs font-medium">
                    <span class="text-white font-bold text-sm">{l.letter}</span> {l.word}
                  </span>
                ))}
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-display font-bold text-gray-900 group-hover:text-green-600 transition-colors">
                {w.title}
              </h3>
              <p class="text-sm text-gray-500 font-medium mb-2">{w.subtitle}</p>
              <p class="text-sm text-gray-500 line-clamp-2">{w.description}</p>
              <div class="mt-3 flex items-center justify-between text-xs text-gray-400">
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {w.duration}
                </span>
                <span class="text-green-500">Start &rarr;</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         QUICK REFERENCE — Downloadable H.A.B.I.T.S. poster
         ═══════════════════════════════════════════════════ -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20" id="habits-poster">
      <div class="reveal max-w-2xl mx-auto bg-white rounded-2xl border border-gray-100 shadow-sm p-8 sm:p-10">
        <p class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-5 text-center">Quick Reference</p>
        <h2 class="text-2xl font-serif text-gray-900 text-center mb-8 tracking-tight">H.A.B.I.T.S.</h2>

        <div class="space-y-4">
          {HABITS.map((habit) => {
            const colors = letterColors[habit.letter] || letterColors.H
            return (
              <div class="flex items-center gap-4">
                <div class={`w-9 h-9 rounded-lg ${colors.accent} flex items-center justify-center flex-shrink-0`}>
                  <span class="text-white text-sm font-bold">{habit.letter}</span>
                </div>
                <div>
                  <span class="font-semibold text-gray-900">{habit.name}</span>
                  <span class="text-gray-300 mx-2">&mdash;</span>
                  <span class="text-sm text-gray-500">{habit.tagline}</span>
                </div>
              </div>
            )
          })}
        </div>

        <div class="mt-8 pt-5 border-t border-gray-100 text-center">
          <p class="text-sm text-gray-400 mb-4">6 habits. Every day. Ages 0 to 16.</p>
          <button
            id="download-poster"
            class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-gray-200 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
            Save this poster
          </button>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         BRIDGE → Grow
         ═══════════════════════════════════════════════════ -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
      <div class="reveal rounded-3xl bg-gradient-to-r from-purple-50 to-indigo-50 border border-purple-100/80 p-8 sm:p-12 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="flex-1">
          <p class="font-serif text-xl sm:text-2xl text-gray-900 tracking-tight leading-snug">
            Want to understand why these habits matter?<br class="hidden sm:block" />
            See what's happening inside your child's body.
          </p>
        </div>
        <a href="/discover" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-gray-900 text-white font-semibold text-sm hover:bg-gray-800 transition-colors shadow-sm flex-shrink-0">
          Go to Grow
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </section>

  </main>

  <Footer />
  <MobileTabBar />
</BaseLayout>

<style>
  .font-serif {
    font-family: 'DM Serif Display', Georgia, 'Times New Roman', serif;
  }

  @media print {
    nav, footer, header, .md\:hidden, [class*="MobileTabBar"],
    section:not(#habits-poster) { display: none !important; }
    #habits-poster { padding: 0 !important; }
    #download-poster { display: none !important; }
  }
</style>

<script>
  document.getElementById('download-poster')?.addEventListener('click', () => {
    window.print()
  })

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible')
          io.unobserve(e.target)
        }
      })
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  )
  document.querySelectorAll('.reveal, .img-reveal').forEach((el) => io.observe(el))
</script>
