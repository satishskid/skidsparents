---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import { HABITS, getTodaysHabit } from '@/lib/content/habits'

const todaysHabit = getTodaysHabit()
---

<BaseLayout
  title="H.A.B.I.T.S. Framework"
  description="The SKIDS H.A.B.I.T.S. framework — 6 daily habits that build healthy, happy, high-performing children. Evidence-based parenting for Indian families."
>
  <Navbar />

  <main class="min-h-screen bg-gray-50">
    <!-- Hero -->
    <section class="bg-gradient-to-br from-green-600 to-emerald-700 py-14 text-center text-white">
      <div class="max-w-2xl mx-auto px-4">
        <p class="text-green-200 text-sm font-semibold uppercase tracking-widest mb-2">SKIDS Framework</p>
        <h1 class="text-4xl sm:text-5xl font-display font-extrabold tracking-tight">H.A.B.I.T.S.</h1>
        <p class="mt-4 text-lg text-green-100">6 daily habits that build healthy, happy, high-performing children</p>
        <div class="mt-6 flex flex-wrap justify-center gap-2">
          {HABITS.map(h => (
            <a href={`/habits/${h.key}`}
              class="w-10 h-10 rounded-xl bg-white/20 hover:bg-white/30 flex items-center justify-center text-xl font-bold transition-colors"
              title={h.name}
            >
              {h.letter}
            </a>
          ))}
        </div>
      </div>
    </section>

    <div class="max-w-3xl mx-auto px-4 py-10 space-y-6">
      <!-- Today's Habit -->
      <div class={`rounded-2xl p-6 text-white bg-gradient-to-br ${todaysHabit.bgColor.replace('bg-', 'from-')} to-emerald-700`}>
        <p class="text-white/70 text-xs font-semibold uppercase tracking-wider mb-1">Today's Focus</p>
        <div class="flex items-center gap-3">
          <span class="text-4xl">{todaysHabit.emoji}</span>
          <div>
            <h2 class="text-xl font-bold">{todaysHabit.letter} — {todaysHabit.name}</h2>
            <p class="text-white/80 text-sm mt-0.5">{todaysHabit.tagline}</p>
          </div>
        </div>
        <p class="mt-3 text-sm text-white/90 bg-white/10 rounded-xl p-3">💡 {todaysHabit.tip}</p>
        <a href={`/habits/${todaysHabit.key}`} class="mt-3 inline-block text-sm font-semibold text-white underline underline-offset-2">
          Learn more →
        </a>
      </div>

      <!-- All 6 Habits -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {HABITS.map(habit => (
          <a href={`/habits/${habit.key}`}
            class="group bg-white rounded-2xl border border-gray-100 p-5 hover:shadow-md hover:border-green-200 transition-all"
          >
            <div class="flex items-start gap-4">
              <div class={`w-12 h-12 rounded-xl ${habit.bgColor} flex items-center justify-center text-white text-2xl shadow-sm flex-shrink-0`}>
                {habit.emoji}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class={`text-xs font-bold ${habit.color} bg-gray-50 w-6 h-6 rounded-md flex items-center justify-center`}>
                    {habit.letter}
                  </span>
                  <h3 class="font-display font-bold text-gray-900 group-hover:text-green-700 transition-colors">
                    {habit.name}
                  </h3>
                </div>
                <p class="text-sm text-gray-500">{habit.tagline}</p>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Why H.A.B.I.T.S. -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6">
        <h2 class="font-display font-bold text-gray-900 text-lg mb-3">Why H.A.B.I.T.S.?</h2>
        <p class="text-gray-600 text-sm leading-relaxed">
          The SKIDS H.A.B.I.T.S. framework is built on decades of pediatric neuroscience research.
          Each letter represents a daily practice that directly impacts your child's brain development,
          physical health, and emotional wellbeing. Small daily habits compound into extraordinary outcomes.
        </p>
        <div class="mt-4 grid grid-cols-3 gap-3 text-center">
          <div class="bg-green-50 rounded-xl p-3">
            <div class="text-2xl font-bold text-green-600">6</div>
            <div class="text-xs text-gray-500 mt-1">Daily Habits</div>
          </div>
          <div class="bg-blue-50 rounded-xl p-3">
            <div class="text-2xl font-bold text-blue-600">0–16</div>
            <div class="text-xs text-gray-500 mt-1">Years Covered</div>
          </div>
          <div class="bg-purple-50 rounded-xl p-3">
            <div class="text-2xl font-bold text-purple-600">∞</div>
            <div class="text-xs text-gray-500 mt-1">Impact</div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
  <MobileTabBar />
</BaseLayout>

<script>
  if (typeof window !== 'undefined' && (window as any).skidsTrack) {
    (window as any).skidsTrack('content_view', {
      funnel_stage: 'interest',
      content_type: 'habit',
      content_id: 'habits_index',
    })
  }
</script>
