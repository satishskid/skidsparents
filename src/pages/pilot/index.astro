---
import PilotLanding from '@/components/pilot/PilotLanding'
export const prerender = false
const url = new URL(Astro.request.url)
const inviteCode = url.searchParams.get('code') || ''
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SKIDS Intelligence — Pilot Program</title>
    <meta name="description" content="Experience SKIDS Intelligence — AI-powered pediatric health insights personalized to your child." />
    <meta name="theme-color" content="#16a34a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      @import '../../styles/global.css';
    </style>
  </head>
  <body class="min-h-screen bg-white font-sans antialiased">
    <PilotLanding client:load initialCode={inviteCode} />
  </body>
</html>
