---
/**
 * /pilot/companion — SKIDS Companion Pilot
 *
 * Controlled testing environment for the Bayesian projection engine.
 * This page is NOT linked from the main navigation.
 * Access: /pilot/companion (direct URL only)
 *
 * What this tests:
 * - Parent enters an observation about their child
 * - The Bayesian engine projects probable conditions
 * - Results show: condition name, probability, urgency, evidence, next steps
 * - Doctor can then refine/confirm/dismiss each projection
 *
 * This is the core SKIDS IP — the intelligence that makes SKIDS
 * different from every other child health app.
 */

import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'

export const prerender = false
---

<BaseLayout
  title="SKIDS Companion — Pilot Testing"
  description="Controlled pilot environment for testing the SKIDS Companion intelligence engine."
>
  <Navbar />

  <main class="min-h-screen bg-gray-50">

    <!-- Header -->
    <section class="bg-gray-950 py-12">
      <div class="max-w-3xl mx-auto px-5 sm:px-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="px-2.5 py-1 rounded-full bg-amber-500/20 text-amber-400 text-[10px] font-bold uppercase tracking-wider">Pilot</span>
          <span class="px-2.5 py-1 rounded-full bg-red-500/20 text-red-400 text-[10px] font-bold uppercase tracking-wider">Internal Only</span>
        </div>
        <h1 class="font-serif text-3xl sm:text-4xl text-white tracking-tight">
          SKIDS Companion
        </h1>
        <p class="mt-3 text-white/40 leading-relaxed max-w-xl">
          Bayesian projection engine. Enter a parent observation, provide child context,
          and see what the intelligence engine projects. This is NOT for parents &mdash;
          this is for controlled clinical validation.
        </p>
      </div>
    </section>

    <!-- Pilot Interface -->
    <section class="max-w-3xl mx-auto px-5 sm:px-8 py-10">

      <!-- Pilot form -->
      <div id="pilot-interface" class="hidden space-y-6">

        <!-- Child context -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Child Context</h2>
          <div class="grid sm:grid-cols-3 gap-4">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Age (months)</label>
              <input type="number" id="child-age" value="18" min="0" max="216"
                class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-green-500/20 focus:border-green-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Gender</label>
              <select id="child-gender" class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-green-500/20 focus:border-green-500">
                <option value="male">Male</option>
                <option value="female">Female</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Birth type</label>
              <select id="birth-type" class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-green-500/20 focus:border-green-500">
                <option value="term">Full term</option>
                <option value="preterm">Preterm (&lt;37 weeks)</option>
                <option value="post-term">Post-term (&gt;42 weeks)</option>
              </select>
            </div>
          </div>
          <div class="mt-4">
            <label class="block text-xs font-medium text-gray-600 mb-1">Additional context (optional)</label>
            <input type="text" id="additional-context" placeholder="e.g., family history of asthma, currently breastfeeding, born at 34 weeks..."
              class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-green-500/20 focus:border-green-500" />
          </div>
        </div>

        <!-- Observation input -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Parent Observation</h2>
          <textarea id="observation-input" rows="3"
            placeholder="Enter a parent observation exactly as they might say it...&#10;e.g., &quot;My 18-month-old isn't walking yet and seems to drag one leg&quot;"
            class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm leading-relaxed focus:outline-none focus:ring-2 focus:ring-green-500/20 focus:border-green-500 resize-none"></textarea>
          <div class="mt-4 flex items-center justify-between">
            <div class="flex gap-2 flex-wrap">
              <button class="sample-obs px-3 py-1.5 rounded-full bg-gray-100 text-gray-600 text-xs hover:bg-gray-200 transition-colors" data-obs="my child isn't talking at 2 years old">speech delay</button>
              <button class="sample-obs px-3 py-1.5 rounded-full bg-gray-100 text-gray-600 text-xs hover:bg-gray-200 transition-colors" data-obs="my baby keeps squinting at things and sits very close to the TV">vision concern</button>
              <button class="sample-obs px-3 py-1.5 rounded-full bg-gray-100 text-gray-600 text-xs hover:bg-gray-200 transition-colors" data-obs="he doesn't respond when I call his name and avoids eye contact">behavioral</button>
              <button class="sample-obs px-3 py-1.5 rounded-full bg-gray-100 text-gray-600 text-xs hover:bg-gray-200 transition-colors" data-obs="she refuses to eat anything except rice and milk">nutrition</button>
              <button class="sample-obs px-3 py-1.5 rounded-full bg-gray-100 text-gray-600 text-xs hover:bg-gray-200 transition-colors" data-obs="my 18-month-old isn't walking yet and seems unsteady">motor delay</button>
            </div>
            <button id="run-projection" class="px-5 py-2.5 rounded-xl bg-gray-900 text-white text-sm font-medium hover:bg-gray-800 transition-colors disabled:opacity-50 flex-shrink-0">
              Run Projection
            </button>
          </div>
        </div>

        <!-- Loading -->
        <div id="loading-state" class="hidden">
          <div class="bg-white rounded-2xl border border-gray-200 p-8 text-center">
            <div class="inline-flex items-center gap-3 text-gray-500">
              <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Running Bayesian projection engine...
            </div>
          </div>
        </div>

        <!-- Results -->
        <div id="projection-results" class="hidden space-y-4"></div>

        <!-- Error -->
        <div id="error-state" class="hidden">
          <div class="bg-red-50 rounded-2xl border border-red-200 p-6">
            <p class="text-red-700 text-sm font-medium">Projection failed</p>
            <p id="error-message" class="text-red-600 text-sm mt-1"></p>
          </div>
        </div>

      </div>

    </section>
  </main>
</BaseLayout>

<style>
  .font-serif {
    font-family: 'DM Serif Display', Georgia, 'Times New Roman', serif;
  }
</style>

<script>
  // ── No auth required for pilot — direct access ──
  const token = localStorage.getItem('firebase_token') // optional, passed to API if available
  const pilotInterface = document.getElementById('pilot-interface')!
  pilotInterface.classList.remove('hidden')

  // ── Sample observations ──
  document.querySelectorAll('.sample-obs').forEach((btn) => {
    btn.addEventListener('click', () => {
      const obs = (btn as HTMLElement).dataset.obs || ''
      ;(document.getElementById('observation-input') as HTMLTextAreaElement).value = obs
    })
  })

  // ── Run projection ──
  const runBtn = document.getElementById('run-projection') as HTMLButtonElement
  const loadingState = document.getElementById('loading-state')!
  const resultsDiv = document.getElementById('projection-results')!
  const errorState = document.getElementById('error-state')!
  const errorMsg = document.getElementById('error-message')!

  runBtn.addEventListener('click', async () => {
    const observation = (document.getElementById('observation-input') as HTMLTextAreaElement).value.trim()
    if (!observation) return

    const ageMonths = parseInt((document.getElementById('child-age') as HTMLInputElement).value, 10) || 18
    const gender = (document.getElementById('child-gender') as HTMLSelectElement).value
    const birthType = (document.getElementById('birth-type') as HTMLSelectElement).value
    const additionalContext = (document.getElementById('additional-context') as HTMLInputElement).value.trim()

    // Show loading
    runBtn.disabled = true
    loadingState.classList.remove('hidden')
    resultsDiv.classList.add('hidden')
    resultsDiv.innerHTML = ''
    errorState.classList.add('hidden')

    try {
      const res = await fetch('/api/pilot/companion', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(token ? { Authorization: `Bearer ${token}` } : {}),
        },
        body: JSON.stringify({
          observation,
          childAgeMonths: ageMonths,
          gender,
          birthType,
          additionalContext,
        }),
      })

      const data = await res.json() as any

      if (!res.ok) {
        throw new Error(data.error || `HTTP ${res.status}`)
      }

      // Render results
      loadingState.classList.add('hidden')
      resultsDiv.classList.remove('hidden')

      // Meta info
      const metaHtml = `
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Projection Summary</h2>
          <div class="grid sm:grid-cols-4 gap-4 text-sm">
            <div>
              <span class="text-gray-400 text-xs">Domains detected</span>
              <p class="font-medium text-gray-900">${(data.domainsDetected || []).join(', ') || 'None'}</p>
            </div>
            <div>
              <span class="text-gray-400 text-xs">Conditions projected</span>
              <p class="font-medium text-gray-900">${data.projectionsCount || 0}</p>
            </div>
            <div>
              <span class="text-gray-400 text-xs">Confidence</span>
              <p class="font-medium text-gray-900">${data.confidence ? (data.confidence * 100).toFixed(0) + '%' : 'N/A'}</p>
            </div>
            <div>
              <span class="text-gray-400 text-xs">Computed at</span>
              <p class="font-medium text-gray-900">${data.computedAt ? new Date(data.computedAt).toLocaleTimeString() : 'N/A'}</p>
            </div>
          </div>
          ${data.clarifyingQuestions?.length ? `
            <div class="mt-4 pt-4 border-t border-gray-100">
              <span class="text-gray-400 text-xs">Clarifying questions for parent</span>
              <ul class="mt-1 space-y-1">
                ${data.clarifyingQuestions.map((q: string) => `<li class="text-sm text-gray-600">• ${q}</li>`).join('')}
              </ul>
            </div>
          ` : ''}
        </div>
      `
      resultsDiv.innerHTML = metaHtml

      // Each projection
      const projections = data.projections || []
      projections
        .sort((a: any, b: any) => b.adjustedProbability - a.adjustedProbability)
        .forEach((proj: any) => {
          const urgencyColor = proj.urgency === 'urgent' ? 'text-red-600 bg-red-50' :
                              proj.urgency === 'soon' ? 'text-amber-600 bg-amber-50' :
                              'text-gray-600 bg-gray-50'
          const probPct = (proj.adjustedProbability * 100).toFixed(1)
          const basePct = (proj.baseProbability * 100).toFixed(1)
          const mustNotMiss = proj.mustNotMiss
            ? '<span class="px-2 py-0.5 rounded-full bg-red-100 text-red-700 text-[10px] font-bold uppercase">Must not miss</span>'
            : ''

          const card = document.createElement('div')
          card.className = 'bg-white rounded-2xl border border-gray-200 overflow-hidden'
          card.innerHTML = `
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-3">
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="font-semibold text-gray-900">${proj.conditionName}</h3>
                    ${mustNotMiss}
                  </div>
                  <p class="text-xs text-gray-400">${proj.domain} · ${proj.category} ${proj.icd10 ? '· ' + proj.icd10 : ''}</p>
                </div>
                <div class="text-right flex-shrink-0">
                  <div class="text-2xl font-bold text-gray-900">${probPct}%</div>
                  <div class="text-[10px] text-gray-400">base: ${basePct}%</div>
                </div>
              </div>

              <div class="flex items-center gap-2 mb-4">
                <span class="px-2 py-0.5 rounded-full ${urgencyColor} text-[10px] font-semibold uppercase">${proj.urgency}</span>
              </div>

              <p class="text-sm text-gray-600 leading-relaxed mb-4">${proj.parentExplanation || ''}</p>

              <details class="group">
                <summary class="text-xs font-medium text-gray-400 cursor-pointer hover:text-gray-600 transition-colors">
                  Show evidence & details
                </summary>
                <div class="mt-3 space-y-3 text-xs">
                  ${proj.evidenceFor?.length ? `
                    <div>
                      <span class="font-semibold text-green-700">Evidence for:</span>
                      <ul class="mt-1 space-y-0.5 text-gray-600">
                        ${proj.evidenceFor.map((e: string) => `<li>+ ${e}</li>`).join('')}
                      </ul>
                    </div>
                  ` : ''}
                  ${proj.evidenceAgainst?.length ? `
                    <div>
                      <span class="font-semibold text-red-700">Evidence against:</span>
                      <ul class="mt-1 space-y-0.5 text-gray-600">
                        ${proj.evidenceAgainst.map((e: string) => `<li>- ${e}</li>`).join('')}
                      </ul>
                    </div>
                  ` : ''}
                  ${proj.modifiersApplied?.length ? `
                    <div>
                      <span class="font-semibold text-blue-700">Modifiers applied:</span>
                      <ul class="mt-1 space-y-0.5 text-gray-600">
                        ${proj.modifiersApplied.map((m: any) =>
                          `<li>${m.source}: ${m.description} (×${m.multiplier})</li>`
                        ).join('')}
                      </ul>
                    </div>
                  ` : ''}
                  ${proj.parentNextSteps?.length ? `
                    <div>
                      <span class="font-semibold text-gray-700">Parent next steps:</span>
                      <ul class="mt-1 space-y-0.5 text-gray-600">
                        ${proj.parentNextSteps.map((s: string) => `<li>→ ${s}</li>`).join('')}
                      </ul>
                    </div>
                  ` : ''}
                  ${proj.doctorExamPoints?.length ? `
                    <div>
                      <span class="font-semibold text-gray-700">Doctor exam points:</span>
                      <ul class="mt-1 space-y-0.5 text-gray-600">
                        ${proj.doctorExamPoints.map((s: string) => `<li>→ ${s}</li>`).join('')}
                      </ul>
                    </div>
                  ` : ''}
                  ${proj.citation ? `
                    <div>
                      <span class="font-semibold text-gray-700">Citation:</span>
                      <p class="text-gray-500 mt-0.5">${proj.citation}</p>
                    </div>
                  ` : ''}
                </div>
              </details>
            </div>
          `
          resultsDiv.appendChild(card)
        })

      if (projections.length === 0) {
        resultsDiv.innerHTML += `
          <div class="bg-white rounded-2xl border border-gray-200 p-6 text-center">
            <p class="text-gray-500">No conditions projected for this observation.</p>
          </div>
        `
      }

    } catch (err: any) {
      loadingState.classList.add('hidden')
      errorState.classList.remove('hidden')
      errorMsg.textContent = err.message || 'Unknown error'
    } finally {
      runBtn.disabled = false
    }
  })
</script>
