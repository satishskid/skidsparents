---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import ChildDashboard from '@/components/phr/ChildDashboard'

export const prerender = false

const { id } = Astro.params
---

<BaseLayout
  title="Child Health Dashboard"
  description="Track your child's milestones, habits, growth, and observations."
  noIndex
>
  <Navbar />

  <main class="min-h-screen bg-gray-50/50">
    <ChildDashboard client:load childId={id!} />
  </main>

  <MobileTabBar />
</BaseLayout>
