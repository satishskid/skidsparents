---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import UserProfile from '@/components/auth/UserProfile'

export const prerender = true
---

<BaseLayout
  title="My Profile"
  description="Manage your child's profile, settings, and preferences on SKIDS Parent."
>
  <Navbar />

  <main class="max-w-2xl mx-auto px-4 py-6 pb-24 md:pb-12">
    <UserProfile client:load />
  </main>

  <Footer />
  <MobileTabBar />
</BaseLayout>
