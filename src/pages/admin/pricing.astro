---
import PricingManager from '@/components/admin/PricingManager'

export const prerender = false

const adminKey = Astro.locals.runtime?.env?.ADMIN_KEY ?? ''
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SKIDS Admin — Pricing Tiers</title>
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      @import '../../styles/global.css';
    </style>
  </head>
  <body class="min-h-screen bg-gray-50 font-sans antialiased">
    <div class="max-w-5xl mx-auto px-4 py-8">
      <div class="flex items-center gap-3 mb-6">
        <a href="/admin" class="text-sm text-gray-500 hover:text-gray-700">← Admin</a>
        <span class="text-gray-300">/</span>
        <span class="text-sm font-semibold text-gray-800">Pricing Tiers</span>
      </div>
      <PricingManager adminKey={adminKey} client:load />
    </div>
  </body>
</html>
