---
export const prerender = false
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Provider Login — SKIDS</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
  <div id="login-root" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 max-w-sm w-full space-y-5">
    <div class="text-center">
      <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center text-white text-2xl font-bold mx-auto shadow-lg shadow-green-500/20">
        S
      </div>
      <h1 class="mt-4 text-xl font-bold text-gray-900">Provider Login</h1>
      <p class="mt-1 text-sm text-gray-500">Sign in to your skids provider account</p>
    </div>

    <div id="error-msg" class="hidden bg-red-50 border border-red-200 rounded-xl px-4 py-3 text-sm text-red-700"></div>

    <button
      id="google-btn"
      class="w-full flex items-center justify-center gap-3 px-4 py-3 rounded-xl border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4" />
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
      </svg>
      Continue with Google
    </button>

    <p class="text-xs text-center text-gray-400">
      Don't have an account?{' '}
      <a href="/provider/signup" class="text-green-600 font-semibold hover:underline">Apply to join</a>
    </p>
  </div>

  <script>
    import { signInWithGoogle } from '@/lib/firebase/client'

    const btn = document.getElementById('google-btn') as HTMLButtonElement
    const errEl = document.getElementById('error-msg') as HTMLDivElement

    function showError(msg: string) {
      errEl.textContent = msg
      errEl.classList.remove('hidden')
    }

    btn.addEventListener('click', async () => {
      btn.disabled = true
      btn.textContent = 'Signing in...'
      errEl.classList.add('hidden')
      try {
        const user = await signInWithGoogle()
        const token = await user.getIdToken()
        // Verify this is a known provider by calling /api/provider/me
        const res = await fetch('/api/provider/me', {
          headers: { Authorization: `Bearer ${token}` },
        })
        if (res.status === 403) {
          showError('Your account is pending review. We\'ll contact you once approved.')
          btn.disabled = false
          btn.textContent = 'Continue with Google'
          return
        }
        if (!res.ok) {
          showError('No provider account found. Please sign up first.')
          btn.disabled = false
          btn.textContent = 'Continue with Google'
          return
        }
        window.location.href = '/provider'
      } catch (err: any) {
        if (err?.code !== 'auth/popup-closed-by-user') {
          showError('Sign-in failed. Please try again.')
        }
        btn.disabled = false
        btn.textContent = 'Continue with Google'
      }
    })
  </script>
</body>
</html>
