---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import ChatWidget from '@/components/chat/ChatWidget'
import { SERVICES, SERVICE_CATEGORIES, type Service } from '@/lib/content/services'

export const prerender = true
---

<BaseLayout
  title="Health Services"
  description="Book evidence-based child health services — vision screening, nutrition analysis, behavioral assessment, sleep programs, speech therapy, and more."
>
  <Navbar />

  <main class="section-warm">
    <!-- Header -->
    <section class="pt-8 pb-4 px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <span class="text-xs font-semibold text-orange-600 uppercase tracking-wider">D2C Health Services</span>
        <h1 class="mt-2 text-2xl sm:text-3xl font-display font-bold text-gray-900">
          Medical-grade care, delivered digitally
        </h1>
        <p class="mt-2 text-sm text-gray-500 max-w-2xl">
          Evidence-based interventions personalized to your child. Book screenings, consultations, and programs — from your phone.
        </p>
      </div>
    </section>

    <!-- Category tabs -->
    <section class="px-4 sm:px-6 lg:px-8 pb-6">
      <div class="max-w-7xl mx-auto">
        <div class="flex gap-2 overflow-x-auto no-scrollbar pb-2" id="category-tabs">
          {SERVICE_CATEGORIES.map((cat) => (
            <button
              data-category={cat.key}
              class:list={[
                'category-tab flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium transition-all border',
                cat.key === 'all'
                  ? 'bg-gray-900 text-white border-gray-900'
                  : 'bg-white text-gray-600 border-gray-200 hover:border-gray-300 hover:bg-gray-50',
              ]}
            >
              {cat.label}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Service cards grid -->
    <section class="px-4 sm:px-6 lg:px-8 pb-16">
      <div class="max-w-7xl mx-auto">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" id="services-grid">
          {SERVICES.map((svc) => (
            <div
              class="service-card card-hover p-5 rounded-2xl bg-white border border-gray-100 shadow-sm"
              data-category={svc.category}
              id={svc.slug}
            >
              <div class="flex items-center justify-between mb-3">
                <span class="text-3xl">{svc.emoji}</span>
                <div class="flex items-center gap-2">
                  {svc.badge && (
                    <span class="text-[10px] font-semibold px-2.5 py-0.5 rounded-full bg-green-50 text-green-700 border border-green-200 uppercase tracking-wider">
                      {svc.badge}
                    </span>
                  )}
                  <span class:list={[
                    'text-[10px] font-semibold px-2.5 py-0.5 rounded-full uppercase tracking-wider',
                    svc.providerType === 'skids'
                      ? 'bg-blue-50 text-blue-700 border border-blue-200'
                      : 'bg-gray-100 text-gray-600 border border-gray-200',
                  ]}>
                    {svc.providerType === 'skids' ? 'SKIDS' : 'Partner'}
                  </span>
                </div>
              </div>

              <h3 class="text-base font-display font-bold text-gray-900">{svc.name}</h3>
              <p class="mt-1.5 text-sm text-gray-500 leading-relaxed line-clamp-2">{svc.description}</p>

              <div class="mt-4 flex items-center justify-between">
                <div>
                  <span class="text-lg font-bold text-gray-900">{svc.priceLabel}</span>
                  <span class="ml-1.5 text-xs text-gray-400">{svc.deliveryLabel}</span>
                </div>
                <button class="px-4 py-2 rounded-xl bg-green-600 text-white text-sm font-semibold hover:bg-green-700 transition-colors shadow-sm">
                  Book
                </button>
              </div>
            </div>
          ))}
        </div>

        <!-- Empty state -->
        <div id="empty-state" class="hidden py-16 text-center">
          <span class="text-4xl mb-4 block">🔍</span>
          <p class="text-gray-500 text-sm">No services found in this category.</p>
        </div>
      </div>
    </section>

    <!-- Trust strip -->
    <section class="py-12 px-4 sm:px-6 lg:px-8 section-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
          <div>
            <div class="text-2xl font-display font-bold text-gray-900">10+</div>
            <div class="mt-1 text-xs text-gray-500">D2C Services</div>
          </div>
          <div>
            <div class="text-2xl font-display font-bold text-gray-900">FDA</div>
            <div class="mt-1 text-xs text-gray-500">Approved Devices</div>
          </div>
          <div>
            <div class="text-2xl font-display font-bold text-gray-900">100%</div>
            <div class="mt-1 text-xs text-gray-500">Evidence-Based</div>
          </div>
          <div>
            <div class="text-2xl font-display font-bold text-gray-900">24/7</div>
            <div class="mt-1 text-xs text-gray-500">AI Support</div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <ChatWidget client:idle />
  <MobileTabBar />
</BaseLayout>

<script>
  // Client-side category filtering
  const tabs = document.querySelectorAll<HTMLButtonElement>('.category-tab')
  const cards = document.querySelectorAll<HTMLElement>('.service-card')
  const emptyState = document.getElementById('empty-state')

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const category = tab.dataset.category

      // Update active tab
      tabs.forEach((t) => {
        if (t.dataset.category === category) {
          t.classList.add('bg-gray-900', 'text-white', 'border-gray-900')
          t.classList.remove('bg-white', 'text-gray-600', 'border-gray-200')
        } else {
          t.classList.remove('bg-gray-900', 'text-white', 'border-gray-900')
          t.classList.add('bg-white', 'text-gray-600', 'border-gray-200')
        }
      })

      // Filter cards
      let visibleCount = 0
      cards.forEach((card) => {
        if (category === 'all' || card.dataset.category === category) {
          card.style.display = ''
          visibleCount++
        } else {
          card.style.display = 'none'
        }
      })

      // Toggle empty state
      if (emptyState) {
        emptyState.classList.toggle('hidden', visibleCount > 0)
      }
    })
  })
</script>
