---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import { ORGANS } from '@/lib/content/organs'

export const prerender = true

const bodySystems = ORGANS.slice(0, 11)
const developmentDomains = ORGANS.slice(11)
---

<BaseLayout
  title="Grow — How Your Child's Body Works | SKIDS"
  description="16 interactive journeys through your child's body. Understand how each organ and developmental system works — and what you can do to nurture it."
>
  <Navbar />

  <main class="min-h-screen">

    <!-- ═══════════════════════════════════════════════════
         HERO — Emotional, image-led.
         ═══════════════════════════════════════════════════ -->
    <section class="relative overflow-hidden bg-gray-950">
      <div class="absolute inset-0 bg-gradient-to-br from-green-900 via-gray-950 to-emerald-900"></div>
      <div class="relative max-w-4xl mx-auto px-5 sm:px-8 py-20 sm:py-28 text-center">
        <p class="reveal text-green-400 text-xs font-semibold uppercase tracking-widest mb-4">Grow</p>
        <h1 class="reveal font-serif text-[clamp(2rem,5vw,3.5rem)] leading-[1.08] tracking-tight text-white">
          Right now, your child's body<br class="hidden sm:block" />
          is building itself.
        </h1>
        <p class="reveal reveal-delay-1 mt-5 text-lg text-white/50 max-w-xl mx-auto leading-relaxed">
          Their heart beats 100,000 times a day. Their bones are growing while they sleep.
          Their brain is wiring itself around every experience they have.
          Understand what's happening inside &mdash; and what you can do to nurture it.
        </p>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         BODY SYSTEMS — 11 interactive journeys
         ═══════════════════════════════════════════════════ -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <div class="reveal mb-10">
        <h2 class="text-2xl font-serif text-gray-900 tracking-tight">Body Systems</h2>
        <p class="mt-1 text-gray-500">11 systems that keep your child growing and thriving</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {bodySystems.map((organ, i) => (
          <a href={`/discover/${organ.slug}`} class={`reveal group card-hover block p-6 rounded-2xl bg-white border border-gray-100 shadow-sm`}>
            <div class="flex items-start gap-4">
              <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${organ.gradient} flex items-center justify-center text-2xl shadow-sm`}>
                {organ.emoji}
              </div>
              <div class="flex-1">
                <h3 class="font-display font-bold text-gray-900 group-hover:text-green-600 transition-colors">
                  {organ.name}
                </h3>
                <p class="mt-1 text-sm text-gray-500">{organ.wonderFact}</p>
                <div class="mt-3 flex items-center gap-3 text-xs text-gray-400">
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    {organ.duration}
                  </span>
                  <span class="flex items-center gap-1 text-green-500">
                    Explore &rarr;
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         DEVELOPMENTAL DOMAINS
         ═══════════════════════════════════════════════════ -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <div class="reveal mb-10">
        <h2 class="text-2xl font-serif text-gray-900 tracking-tight">Developmental Domains</h2>
        <p class="mt-1 text-gray-500">5 key areas that shape who your child becomes</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {developmentDomains.map((domain) => (
          <a href={`/discover/${domain.slug}`} class="reveal group card-hover block p-6 rounded-2xl bg-white border border-gray-100 shadow-sm">
            <div class="flex items-start gap-4">
              <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${domain.gradient} flex items-center justify-center text-2xl shadow-sm`}>
                {domain.emoji}
              </div>
              <div class="flex-1">
                <h3 class="font-display font-bold text-gray-900 group-hover:text-green-600 transition-colors">
                  {domain.name}
                </h3>
                <p class="mt-1 text-sm text-gray-500">{domain.wonderFact}</p>
                <div class="mt-3 flex items-center gap-3 text-xs text-gray-400">
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    {domain.duration}
                  </span>
                  <span class="flex items-center gap-1 text-green-500">
                    Explore &rarr;
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         BRIDGE → Practice
         ═══════════════════════════════════════════════════ -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
      <div class="reveal rounded-3xl bg-gradient-to-r from-green-50 to-emerald-50 border border-green-100/80 p-8 sm:p-12 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="flex-1">
          <p class="font-serif text-xl sm:text-2xl text-gray-900 tracking-tight leading-snug">
            Now that you understand the body,<br class="hidden sm:block" />
            learn the six daily habits that shape it.
          </p>
        </div>
        <a href="/habits" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-green-600 text-white font-semibold text-sm hover:bg-green-500 transition-colors shadow-sm flex-shrink-0">
          Go to Practice
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </section>

  </main>

  <Footer />
  <MobileTabBar />
</BaseLayout>

<style>
  .font-serif {
    font-family: 'DM Serif Display', Georgia, 'Times New Roman', serif;
  }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible')
          io.unobserve(e.target)
        }
      })
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  )
  document.querySelectorAll('.reveal, .img-reveal').forEach((el) => io.observe(el))
</script>
