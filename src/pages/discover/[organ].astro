---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import { ORGANS, type OrganModule } from '@/lib/content/organs'
import { HABITS } from '@/lib/content/habits'

export const prerender = true

export function getStaticPaths() {
  return ORGANS.map((organ) => ({
    params: { organ: organ.slug },
    props: { organ },
  }))
}

interface Props {
  organ: OrganModule
}

const { organ } = Astro.props

// Related habit
const relatedHabit = HABITS.find((h) => h.key === organ.relatedHabit)

// Prev/next navigation
const idx = ORGANS.findIndex((o) => o.slug === organ.slug)
const prevOrgan = ORGANS[(idx - 1 + ORGANS.length) % ORGANS.length]
const nextOrgan = ORGANS[(idx + 1) % ORGANS.length]

// Fetch related blogs at build time
let relatedBlogs: any[] = []
try {
  const res = await fetch('https://9vhd0onw23.execute-api.ap-south-1.amazonaws.com/published-blogs')
  if (res.ok) {
    const allBlogs: any[] = await res.json()
    relatedBlogs = allBlogs
      .filter((b: any) =>
        organ.relatedCategories.some(
          (cat) =>
            (b.category || '').toLowerCase().includes(cat.toLowerCase()) ||
            cat.toLowerCase().includes((b.category || '').toLowerCase())
        )
      )
      .slice(0, 3)
  }
} catch {}

// SKIDS Guide prompt
const drSkidsPrompt = `Tell me about ${organ.name.toLowerCase()} development in children`
---

<BaseLayout
  title={organ.name}
  description={organ.description}
  ogType="article"
>
  <Navbar />

  <main class="min-h-screen">
    <!-- Hero -->
    <section class={`bg-gradient-to-br ${organ.gradient} py-16 lg:py-24 relative overflow-hidden`}>
      <div class="absolute inset-0 bg-black/10" />
      <div class="max-w-3xl mx-auto px-4 sm:px-6 relative z-10 text-center">
        <a href="/discover" class="inline-flex items-center gap-1 text-white/70 text-sm font-medium hover:text-white transition-colors mb-6">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
          All Organs
        </a>
        <div class="text-6xl mb-4">{organ.emoji}</div>
        <h1 class="text-3xl sm:text-5xl font-display font-extrabold text-white tracking-tight">
          {organ.name}
        </h1>
        <p class="mt-4 text-lg text-white/90 max-w-xl mx-auto">
          {organ.description}
        </p>
        <div class="mt-4 inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm rounded-full px-4 py-1.5 text-sm text-white">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {organ.duration} read
        </div>
      </div>
    </section>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 space-y-8">
      <!-- Wonder Fact -->
      <div class="bg-gradient-to-br from-amber-50 to-yellow-50 rounded-2xl p-6 border border-amber-100">
        <div class="flex items-start gap-3">
          <div class="text-2xl">💡</div>
          <div>
            <h2 class="text-sm font-semibold text-amber-800 uppercase tracking-wider">Did You Know?</h2>
            <p class="mt-2 text-gray-800 font-medium">{organ.wonderFact}</p>
          </div>
        </div>
      </div>

      <!-- Related Habit -->
      {relatedHabit && (
        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Habit</h2>
          <div class="flex items-start gap-4">
            <div class={`w-12 h-12 rounded-xl ${relatedHabit.bgColor} flex items-center justify-center text-white text-2xl shadow-sm`}>
              {relatedHabit.emoji}
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <span class={`text-xs font-bold ${relatedHabit.color} bg-gray-50 w-6 h-6 rounded-md flex items-center justify-center`}>
                  {relatedHabit.letter}
                </span>
                <h3 class="font-display font-bold text-gray-900">{relatedHabit.name}</h3>
              </div>
              <p class="mt-1 text-sm text-gray-600">{relatedHabit.tagline}</p>
              <p class="mt-2 text-sm text-gray-500">{relatedHabit.tip}</p>
            </div>
          </div>
        </div>
      )}

      <!-- Ask SKIDS Guide -->
      <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-2xl p-6 border border-green-100">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center text-white font-bold shadow-sm">
            S
          </div>
          <div class="flex-1">
            <h2 class="font-display font-bold text-gray-900">Ask SKIDS Guide</h2>
            <p class="mt-1 text-sm text-gray-600">Have questions about {organ.name.toLowerCase()}?</p>
            <a
              href={`/timeline?q=${encodeURIComponent(drSkidsPrompt)}`}
              class="mt-3 inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-green-600 text-white text-sm font-semibold hover:bg-green-700 transition-colors"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
              </svg>
              Ask about {organ.name}
            </a>
          </div>
        </div>
      </div>

      <!-- Related Blog Posts -->
      {relatedBlogs.length > 0 && (
        <div>
          <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Articles</h2>
          <div class="grid sm:grid-cols-3 gap-4">
            {relatedBlogs.map((blog: any) => (
              <a
                href={`/blog/${blog.blogId}`}
                class="group rounded-xl overflow-hidden border border-gray-100 bg-white hover:shadow-md transition-shadow"
              >
                {blog.thumbnailUrl && (
                  <div class="aspect-[16/10] overflow-hidden">
                    <img
                      src={blog.thumbnailUrl}
                      alt=""
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-3">
                  <span class="text-[10px] font-semibold text-green-600 uppercase">{blog.category}</span>
                  <h3 class="text-sm font-semibold text-gray-900 mt-1 line-clamp-2 group-hover:text-green-600 transition-colors">
                    {blog.title}
                  </h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Prev/Next Navigation -->
      <div class="flex gap-3 pt-4">
        <a
          href={`/discover/${prevOrgan.slug}`}
          class="flex-1 flex items-center gap-3 px-4 py-3 rounded-xl bg-white border border-gray-100 hover:bg-gray-50 transition-colors group"
        >
          <svg class="w-4 h-4 text-gray-400 group-hover:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
          <div>
            <div class="text-[10px] text-gray-400 uppercase tracking-wider">Previous</div>
            <div class="text-sm font-semibold text-gray-900">{prevOrgan.emoji} {prevOrgan.name}</div>
          </div>
        </a>
        <a
          href={`/discover/${nextOrgan.slug}`}
          class="flex-1 flex items-center justify-end gap-3 px-4 py-3 rounded-xl bg-white border border-gray-100 hover:bg-gray-50 transition-colors group text-right"
        >
          <div>
            <div class="text-[10px] text-gray-400 uppercase tracking-wider">Next</div>
            <div class="text-sm font-semibold text-gray-900">{nextOrgan.name} {nextOrgan.emoji}</div>
          </div>
          <svg class="w-4 h-4 text-gray-400 group-hover:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </a>
      </div>

      <!-- Share -->
      <div class="bg-white rounded-2xl border border-gray-100 p-5">
        <p class="text-sm font-semibold text-gray-500 mb-3">Share this with other parents</p>
        <div id="share-buttons-root"></div>
      </div>

      <!-- Back to all -->
      <div class="text-center">
        <a href="/discover" class="text-sm text-green-600 hover:text-green-700 font-medium">
          ← Explore All 16 Organs
        </a>
      </div>
    </div>
  </main>

  <Footer />
  <MobileTabBar />
</BaseLayout>

<script define:vars={{ organSlug: organ.slug, organName: organ.name }}>
  // Track organ view
  if (typeof window !== 'undefined' && window.skidsTrack) {
    window.skidsTrack('content_view', {
      funnel_stage: 'interest',
      content_type: 'organ',
      content_id: organSlug,
      content_title: organName,
    })
  }

  // Render share buttons
  const root = document.getElementById('share-buttons-root')
  if (root) {
    const platforms = [
      { id: 'whatsapp', label: 'WhatsApp', color: 'bg-green-500', icon: '💬' },
      { id: 'facebook', label: 'Facebook', color: 'bg-blue-600', icon: '📘' },
      { id: 'twitter', label: 'Twitter', color: 'bg-black', icon: '🐦' },
      { id: 'copy', label: 'Copy', color: 'bg-gray-100 text-gray-700', icon: '🔗' },
    ]

    const pageUrl = window.location.href
    const text = `Learn about ${organName} — ${pageUrl}`

    root.innerHTML = `<div class="flex flex-wrap gap-2">
      <a href="https://api.whatsapp.com/send?text=${encodeURIComponent(text + '?utm_source=whatsapp&utm_medium=social&utm_campaign=skids_share_organ')}"
        target="_blank" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-green-500 text-white text-sm font-medium">
        💬 WhatsApp
      </a>
      <a href="https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl + '?utm_source=facebook&utm_medium=social&utm_campaign=skids_share_organ')}"
        target="_blank" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-blue-600 text-white text-sm font-medium">
        📘 Facebook
      </a>
      <a href="https://x.com/intent/tweet?text=${encodeURIComponent('Learn about ' + organName + ' — ')}&url=${encodeURIComponent(pageUrl + '?utm_source=twitter&utm_medium=social&utm_campaign=skids_share_organ')}&via=SKIDS58283752"
        target="_blank" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-black text-white text-sm font-medium">
        🐦 Twitter
      </a>
      <button id="copy-organ-link" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-100 text-gray-700 text-sm font-medium">
        🔗 Copy Link
      </button>
    </div>`

    document.getElementById('copy-organ-link')?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(pageUrl)
      const btn = document.getElementById('copy-organ-link')
      if (btn) { btn.textContent = '✅ Copied!'; setTimeout(() => { btn.textContent = '🔗 Copy Link' }, 2000) }
    })
  }
</script>
