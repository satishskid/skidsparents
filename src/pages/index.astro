---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import ContentRow from '@/components/blog/ContentRow'
import ChatWidget from '@/components/chat/ChatWidget'
import OnboardingGateWrapper from '@/components/auth/OnboardingGateWrapper'
export const prerender = false

let blogs: any[] = []
try {
  const res = await fetch('https://9vhd0onw23.execute-api.ap-south-1.amazonaws.com/published-blogs')
  if (res.ok) {
    blogs = (await res.json()) as any[]
    blogs.sort((a: any, b: any) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
  }
} catch {}
const recentBlogs = blogs.slice(0, 6)
---

<BaseLayout
  title="SKIDS — Pediatric Life Record"
  description="The first platform that turns your child's health screenings into a living, intelligent record — connecting parents and pediatricians around what matters most."
>
  <Navbar />
  <main class="overflow-hidden">
    <OnboardingGateWrapper client:load />

    <!-- ═══════════════════════════════════════════════════════════════
         HERO — The single sentence that says everything
         ═══════════════════════════════════════════════════════════════ -->
    <section class="relative min-h-[85vh] flex items-center bg-gray-950">
      <!-- Subtle grid texture -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
      <!-- Gradient accent -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-gradient-to-b from-green-500/10 via-emerald-500/5 to-transparent rounded-full blur-3xl"></div>

      <div class="relative max-w-5xl mx-auto px-6 py-24 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
          <span class="text-xs font-medium text-gray-400 tracking-wide">Now in early access</span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-display font-extrabold text-white leading-[1.08] tracking-tight mb-6">
          Your child's health,<br class="hidden sm:block" />
          <span class="bg-gradient-to-r from-green-400 via-emerald-300 to-teal-400 bg-clip-text text-transparent">fully understood.</span>
        </h1>

        <p class="max-w-2xl mx-auto text-lg sm:text-xl text-gray-400 leading-relaxed mb-10">
          SKIDS builds a living health record from your child's screenings, observations,
          and clinical history — then turns it into intelligence that parents and
          pediatricians can act on together.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/login" class="w-full sm:w-auto px-8 py-4 rounded-xl bg-green-600 text-white font-semibold text-base hover:bg-green-500 transition-colors shadow-lg shadow-green-600/20">
            Start your child's record
          </a>
          <a href="/about" class="w-full sm:w-auto px-8 py-4 rounded-xl border border-white/15 text-gray-300 font-medium text-base hover:bg-white/5 transition-colors">
            See how it works
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         THE PROBLEM — What parents actually live with
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-24 sm:py-32 bg-white">
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-sm font-semibold text-green-600 tracking-widest uppercase mb-4">The reality</p>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-gray-900 leading-tight mb-6">
          Children get screened.<br />Then what?
        </h2>
        <p class="max-w-2xl text-lg text-gray-500 leading-relaxed mb-16">
          Screening catches what's hidden. But the report goes into a drawer.
          The follow-up falls through. And parents are left wondering
          what to do with what they've been told.
        </p>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="group">
            <div class="w-12 h-12 rounded-2xl bg-red-50 flex items-center justify-center mb-5">
              <div class="w-5 h-5 rounded-full border-2 border-red-400 flex items-center justify-center">
                <div class="w-2 h-2 rounded-full bg-red-400"></div>
              </div>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Records are scattered</h3>
            <p class="text-gray-500 leading-relaxed">
              Vaccination cards, screening reports, growth charts, specialist notes — across
              clinics, apps, and paper files. No single view of your child.
            </p>
          </div>

          <div class="group">
            <div class="w-12 h-12 rounded-2xl bg-amber-50 flex items-center justify-center mb-5">
              <div class="w-5 h-5 border-2 border-amber-400 rounded-sm rotate-45"></div>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Signals get missed</h3>
            <p class="text-gray-500 leading-relaxed">
              A borderline hearing result at 6 months. Slow weight gain at 18 months.
              Individually minor — together, they tell a story no one is reading.
            </p>
          </div>

          <div class="group">
            <div class="w-12 h-12 rounded-2xl bg-gray-100 flex items-center justify-center mb-5">
              <div class="w-5 h-0.5 bg-gray-400 relative"><div class="absolute left-1/2 -translate-x-1/2 -top-2 w-0.5 h-4 bg-gray-300"></div></div>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Parents and doctors aren't connected</h3>
            <p class="text-gray-500 leading-relaxed">
              Your pediatrician sees your child for 10 minutes every few months.
              You see them every day. That daily insight never reaches the clinic.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         THE SHIFT — What SKIDS does differently (without revealing HOW)
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-24 sm:py-32 bg-gray-50">
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-sm font-semibold text-green-600 tracking-widest uppercase mb-4">The SKIDS approach</p>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-gray-900 leading-tight mb-6">
          From screening report<br />to living intelligence.
        </h2>
        <p class="max-w-2xl text-lg text-gray-500 leading-relaxed mb-16">
          SKIDS doesn't just store records. It connects every data point — screenings,
          growth measurements, parent observations, clinical notes — into a continuous
          understanding of your child's health trajectory.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <!-- Card 1: Life Record -->
          <div class="bg-white rounded-2xl p-8 border border-gray-200/60 hover:border-green-200 transition-colors">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-xl bg-green-600 flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              </div>
              <h3 class="text-xl font-bold text-gray-900">Pediatric Life Record</h3>
            </div>
            <p class="text-gray-500 leading-relaxed mb-6">
              Every screening result, growth measurement, vaccination, milestone, and parent
              observation — unified into one continuous record that grows with your child
              from birth through adolescence.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Growth tracking</span>
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Milestones</span>
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Vaccinations</span>
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Screening history</span>
            </div>
          </div>

          <!-- Card 2: Intelligence -->
          <div class="bg-white rounded-2xl p-8 border border-gray-200/60 hover:border-green-200 transition-colors">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-xl bg-gray-900 flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
              </div>
              <h3 class="text-xl font-bold text-gray-900">Health Intelligence</h3>
            </div>
            <p class="text-gray-500 leading-relaxed mb-6">
              Your child's records aren't just stored — they're understood. SKIDS identifies
              patterns across developmental domains, flags what needs attention, and surfaces
              guidance personalized to your child's specific health picture.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">8 developmental domains</span>
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Personalized insights</span>
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Risk flagging</span>
            </div>
          </div>

          <!-- Card 3: Co-caring -->
          <div class="bg-white rounded-2xl p-8 border border-gray-200/60 hover:border-green-200 transition-colors">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-xl bg-blue-600 flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <h3 class="text-xl font-bold text-gray-900">Parent + Pediatrician</h3>
            </div>
            <p class="text-gray-500 leading-relaxed mb-6">
              Parents log daily observations. Pediatricians provide clinical oversight.
              SKIDS connects both perspectives — so the doctor sees what happens at home,
              and the parent understands what the doctor sees in the data.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Shared record</span>
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Doctor dashboard</span>
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Clinical protocols</span>
            </div>
          </div>

          <!-- Card 4: Interventions -->
          <div class="bg-white rounded-2xl p-8 border border-gray-200/60 hover:border-green-200 transition-colors">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-xl bg-purple-600 flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
              </div>
              <h3 class="text-xl font-bold text-gray-900">Guided Interventions</h3>
            </div>
            <p class="text-gray-500 leading-relaxed mb-6">
              When a concern is identified, SKIDS doesn't just flag it — it provides
              structured, evidence-based intervention protocols that parents execute
              at home under their pediatrician's guidance.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Evidence-based</span>
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Doctor-prescribed</span>
              <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Home therapy</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         CREDIBILITY — Numbers that matter (without over-claiming)
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-24 sm:py-32 bg-gray-950 text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;"></div>
      <div class="relative max-w-5xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-sm font-semibold text-green-400 tracking-widest uppercase mb-4">Built on real clinical data</p>
          <h2 class="text-3xl sm:text-4xl font-display font-bold leading-tight">
            Not a prototype.<br />A platform with patients.
          </h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-16">
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-display font-extrabold text-green-400 mb-2">15K+</div>
            <div class="text-sm text-gray-400">Children screened</div>
          </div>
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-display font-extrabold text-white mb-2">150+</div>
            <div class="text-sm text-gray-400">Conditions tracked</div>
          </div>
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-display font-extrabold text-white mb-2">8</div>
            <div class="text-sm text-gray-400">Developmental domains</div>
          </div>
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-display font-extrabold text-white mb-2">52</div>
            <div class="text-sm text-gray-400">Intervention pathways</div>
          </div>
        </div>

        <div class="max-w-3xl mx-auto bg-white/5 rounded-2xl border border-white/10 p-8 sm:p-10">
          <p class="text-lg sm:text-xl text-gray-300 leading-relaxed text-center italic">
            "SKIDS began as a multi-specialty pediatric screening program in Hyderabad.
            After screening thousands of children, we realized the screening report was just
            the beginning — what families needed was a continuous system that turned
            that moment of insight into a lifetime of informed care."
          </p>
          <div class="mt-6 text-center">
            <div class="text-sm font-semibold text-white">Dr. Satish Kannan</div>
            <div class="text-xs text-gray-500">Founder, SKIDS</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         THE JOURNEY — What a parent actually experiences
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-24 sm:py-32 bg-white">
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-sm font-semibold text-green-600 tracking-widest uppercase mb-4">The experience</p>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-gray-900 leading-tight mb-16">
          What happens when you bring<br />your child to SKIDS.
        </h2>

        <div class="space-y-12 sm:space-y-0 sm:grid sm:grid-cols-3 sm:gap-12">
          <div class="relative">
            <div class="text-6xl font-display font-extrabold text-gray-100 absolute -top-2 -left-1">1</div>
            <div class="relative pt-10">
              <h3 class="text-lg font-bold text-gray-900 mb-3">Your child gets screened</h3>
              <p class="text-gray-500 leading-relaxed">
                A comprehensive health screening across vision, hearing, development,
                nutrition, and more. In 30 minutes, we see what years of routine checkups might miss.
              </p>
            </div>
          </div>

          <div class="relative">
            <div class="text-6xl font-display font-extrabold text-gray-100 absolute -top-2 -left-1">2</div>
            <div class="relative pt-10">
              <h3 class="text-lg font-bold text-gray-900 mb-3">Intelligence is generated</h3>
              <p class="text-gray-500 leading-relaxed">
                Screening data flows into your child's Life Record. SKIDS analyzes it
                across 8 developmental domains and shows you exactly where your child
                stands — what's thriving, what to monitor, what needs action.
              </p>
            </div>
          </div>

          <div class="relative">
            <div class="text-6xl font-display font-extrabold text-gray-100 absolute -top-2 -left-1">3</div>
            <div class="relative pt-10">
              <h3 class="text-lg font-bold text-gray-900 mb-3">Care becomes continuous</h3>
              <p class="text-gray-500 leading-relaxed">
                Your pediatrician sees the full picture. You get daily guidance personalized
                to your child. Interventions are structured, tracked, and coached — not just
                prescribed and forgotten.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         FOR PEDIATRICIANS — Brief, credible, professional
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-24 sm:py-32 bg-gray-50 border-t border-gray-200/60">
      <div class="max-w-5xl mx-auto px-6">
        <div class="md:grid md:grid-cols-2 md:gap-16 items-center">
          <div>
            <p class="text-sm font-semibold text-blue-600 tracking-widest uppercase mb-4">For pediatricians</p>
            <h2 class="text-3xl sm:text-4xl font-display font-bold text-gray-900 leading-tight mb-6">
              Your patients' health,<br />between visits.
            </h2>
            <p class="text-lg text-gray-500 leading-relaxed mb-8">
              SKIDS gives you a clinical dashboard with every patient's Life Record,
              parent observations, growth trajectories, and flagged concerns —
              so you walk into every appointment already informed.
            </p>
            <a href="/ped/register" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gray-900 text-white font-semibold text-sm hover:bg-gray-800 transition-colors">
              Join as a pediatrician
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>

          <div class="mt-12 md:mt-0">
            <div class="bg-white rounded-2xl border border-gray-200/80 p-6 space-y-4">
              <div class="flex items-center gap-3 pb-4 border-b border-gray-100">
                <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                  <svg class="w-4 h-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                </div>
                <span class="text-sm font-semibold text-gray-900">Doctor Dashboard</span>
              </div>
              <div class="flex items-start gap-3 py-2">
                <div class="w-1.5 h-1.5 rounded-full bg-green-500 mt-2 shrink-0"></div>
                <div>
                  <div class="text-sm font-medium text-gray-900">Daily patient brief</div>
                  <div class="text-xs text-gray-500">AI-generated summary of your panel's health changes</div>
                </div>
              </div>
              <div class="flex items-start gap-3 py-2">
                <div class="w-1.5 h-1.5 rounded-full bg-amber-500 mt-2 shrink-0"></div>
                <div>
                  <div class="text-sm font-medium text-gray-900">Flagged concerns</div>
                  <div class="text-xs text-gray-500">Conditions requiring attention, ranked by urgency</div>
                </div>
              </div>
              <div class="flex items-start gap-3 py-2">
                <div class="w-1.5 h-1.5 rounded-full bg-blue-500 mt-2 shrink-0"></div>
                <div>
                  <div class="text-sm font-medium text-gray-900">Intervention tracking</div>
                  <div class="text-xs text-gray-500">See compliance, streaks, and escalation alerts</div>
                </div>
              </div>
              <div class="flex items-start gap-3 py-2">
                <div class="w-1.5 h-1.5 rounded-full bg-purple-500 mt-2 shrink-0"></div>
                <div>
                  <div class="text-sm font-medium text-gray-900">Clinical protocols</div>
                  <div class="text-xs text-gray-500">Evidence-based, region-aware intervention protocols</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         DAILY CONTENT — Blog feed (keeps community engaged)
         ═══════════════════════════════════════════════════════════════ -->
    {recentBlogs.length > 0 && (
      <section class="py-24 sm:py-32 bg-white border-t border-gray-200/60">
        <div class="max-w-5xl mx-auto px-6">
          <div class="flex items-end justify-between mb-10">
            <div>
              <p class="text-sm font-semibold text-green-600 tracking-widest uppercase mb-3">From the journal</p>
              <h2 class="text-2xl sm:text-3xl font-display font-bold text-gray-900">
                Evidence-based parenting, daily.
              </h2>
            </div>
            <a href="/blog" class="hidden sm:flex items-center gap-1 text-sm font-medium text-green-600 hover:text-green-700">
              All articles
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
          <ContentRow client:load />
        </div>
      </section>
    )}

    <!-- ═══════════════════════════════════════════════════════════════
         FINAL CTA — Clean, confident
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-24 sm:py-32 bg-gray-950 text-white relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-green-500/5 rounded-full blur-3xl"></div>
      <div class="relative max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-3xl sm:text-4xl font-display font-bold leading-tight mb-6">
          Every child's health tells a story.<br />
          <span class="text-green-400">Make sure someone is reading it.</span>
        </h2>
        <p class="text-lg text-gray-400 mb-10">
          Start your child's Pediatric Life Record — free.
        </p>
        <a href="/login" class="inline-flex px-8 py-4 rounded-xl bg-green-600 text-white font-semibold text-base hover:bg-green-500 transition-colors shadow-lg shadow-green-600/20">
          Create your child's record
        </a>
      </div>
    </section>

    <ChatWidget client:load />
  </main>
  <Footer />
  <MobileTabBar />
</BaseLayout>
