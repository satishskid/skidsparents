              </div>
            </div>
            <div class="mt-6 flex items-center justify-between">
              <a href={`/discover/${linkedOrgan.slug}`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-green-600 hover:text-green-700 transition-colors">
                Explore {linkedOrgan.name}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
              <a href="/discover" class="text-xs font-medium text-gray-400 hover:text-gray-600 transition-colors">All 16 organs →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TODAY'S HABIT — always visible -->
    <section class="px-4 sm:px-6 py-4 sm:py-6">
      <div class="max-w-3xl mx-auto">
        <div class="rounded-2xl bg-gradient-to-br from-gray-900 to-gray-800 p-6 sm:p-8 text-white overflow-hidden relative">
          <div class="absolute top-2 right-4 text-[8rem] sm:text-[10rem] font-display font-black text-white/[0.03] leading-none select-none">{linkedHabit.letter}</div>
          <div class="relative">
            <div class="flex items-center gap-2 mb-5">
              {HABITS.map(h => (
                <span class:list={['habit-letter', h.bgColor, h.key === linkedHabit.key ? 'habit-letter-active' : 'opacity-30']}>{h.letter}</span>
              ))}
            </div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xl">{linkedHabit.emoji}</span>
              <span class="text-xs font-bold text-green-400 uppercase tracking-wider">Today's Habit</span>
            </div>
            <h3 class="text-xl sm:text-2xl font-display font-bold">{linkedHabit.name}</h3>
            <p class="mt-1 text-sm text-white/50 font-medium">{linkedHabit.tagline}</p>
            <p class="mt-4 text-sm text-white/80 leading-relaxed max-w-lg">{linkedHabit.description}</p>
            <div class="mt-5 p-3.5 rounded-xl bg-white/10 backdrop-blur-sm border border-white/10">
              <p class="text-sm text-white/90 font-medium">💡 {linkedHabit.tip}</p>
            </div>
            <div class="mt-5">
              <a href="/discover" class="text-xs font-medium text-green-400 hover:text-green-300">All 6 habits →</a>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- DR. SKIDS — always visible -->
    <section class="px-4 sm:px-6 py-6 sm:py-8">
      <div class="max-w-3xl mx-auto">
        <div class="rounded-2xl bg-gradient-to-br from-green-600 via-emerald-600 to-teal-700 p-6 sm:p-8 text-white relative overflow-hidden">
          <div class="absolute top-0 right-0 w-48 h-48 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/4"></div>
          <div class="relative">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-11 h-11 rounded-xl bg-white/20 backdrop-blur-sm flex items-center justify-center text-xl">🩺</div>
              <div>
                <h3 class="text-lg font-display font-bold">Dr. SKIDS</h3>
                <p class="text-[11px] text-white/60">Your child's health companion</p>
              </div>
            </div>
            <p class="text-xs text-white/70 mb-5 leading-relaxed">
              Ask anything — "Is my 18-month-old's speech normal?", "Which vaccines are due at 15 months as per IAP?", "My child eats very little — is growth on track?" Dr. SKIDS answers with paediatric context, not generic internet advice.
            </p>
            <button id="open-chat-btn" class="w-full inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl bg-white text-green-700 font-bold text-sm hover:bg-green-50 transition-colors shadow-lg">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
              </svg>
              Ask Dr. SKIDS
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- MORE ARTICLES — always visible -->
    {remainingBlogs.length > 0 && (
      <ContentRow title="More Articles" emoji="📚" seeAllHref="/blog" client:visible>
        {remainingBlogs.map((blog: any) => (
          <BlogCard
            title={blog.title || 'Untitled'}
            thumbnail={blog.thumbnail}
            category={blog.category}
            author={blog.author}
            date={blog.createdAt}
            link={`/blog/${blog.blogId}`}
          />
        ))}
      </ContentRow>
    )}

    <!-- FINAL CTA — only for new visitors, hidden when logged in -->
    <div id="cta-new">
      <section class="py-14 sm:py-20 bg-gray-900">
        <div class="max-w-lg mx-auto px-5 text-center">
          <div class="text-4xl mb-4">👶</div>
          <h2 class="text-2xl sm:text-3xl font-display font-bold text-white mb-3">Start your child's health record today</h2>
          <p class="text-sm text-gray-400 mb-8 leading-relaxed">
            When you visit a SKIDS paediatrician, they'll have the full picture — every milestone, every observation, every vaccine. That's better care.
          </p>
          <a href="/login" class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-green-500 hover:bg-green-400 text-white font-bold text-base transition-colors shadow-lg shadow-green-900/40">
            Sign in with Google or mobile
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <p class="mt-3 text-xs text-gray-600">Free · No credit card · Works on any phone</p>
        </div>
      </section>
    </div>

  </main>

  <Footer />
  <div class="h-16 md:hidden"></div>
  <ChatWidget client:idle />
  <MobileTabBar />
</BaseLayout>


<script>
  // Capture referral code from URL
  const urlParams = new URLSearchParams(window.location.search)
  const ref = urlParams.get('ref')
  if (ref) {
    localStorage.setItem('skids-referral', ref)
    window.history.replaceState({}, '', window.location.pathname)
  }

  // Wire Dr. SKIDS button
  document.getElementById('open-chat-btn')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-dr-skids'))
  })

  // Track premium benefit clicks — Task 24.2
  document.querySelectorAll<HTMLElement>('.premium-benefit-item').forEach(el => {
    el.addEventListener('click', () => {
      const benefit = el.dataset.benefit || 'unknown'
      if (typeof window.skidsTrack === 'function') {
        window.skidsTrack('premium_benefit_click', { benefit_type: benefit })
      }
      if (typeof window.gtag === 'function') {
        window.gtag('event', 'premium_benefit_click', { benefit_type: benefit })
      }
      if (typeof window.fbq === 'function') {
        window.fbq('trackCustom', 'PremiumBenefitClick', { benefit_type: benefit })
      }
    })
  })

  // Track social proof engagement — Task 25.2
  document.querySelectorAll<HTMLElement>('.social-proof-item').forEach(el => {
    el.addEventListener('click', () => {
      const story = el.dataset.story || 'unknown'
      if (typeof window.skidsTrack === 'function') {
        window.skidsTrack('social_proof_click', { story_type: story })
      }
      if (typeof window.gtag === 'function') {
        window.gtag('event', 'social_proof_click', { story_type: story })
      }
    })
  })

  // ─── Auth-based hero swap ───
  // Prerendered page: show onboarding hero by default.
  // Once Firebase resolves auth state, swap to daily content hero for logged-in users.
  // Uses a short localStorage cache so returning users don't see the flash.
  const CACHE_KEY = 'skids-authed'

  function showReturningHero() {
    const heroNew = document.getElementById('hero-new')
    const heroReturning = document.getElementById('hero-returning')
    const ctaNew = document.getElementById('cta-new')
    if (heroNew) heroNew.classList.add('hidden')
    if (heroReturning) heroReturning.classList.remove('hidden')
    if (ctaNew) ctaNew.classList.add('hidden')
  }

  // Fast path: if we cached auth state from a previous visit, swap immediately (no flash)
  if (localStorage.getItem(CACHE_KEY) === '1') {
    showReturningHero()
  }

  // Authoritative path: wait for Firebase to confirm
  import('/src/lib/firebase/client.js').then(({ auth }) => {
    auth.onAuthStateChanged((user: any) => {
      if (user) {
        localStorage.setItem(CACHE_KEY, '1')
        showReturningHero()
      } else {
        localStorage.removeItem(CACHE_KEY)
        // Ensure onboarding hero is visible (already default, but reset if cache was stale)
        const heroNew = document.getElementById('hero-new')
        const heroReturning = document.getElementById('hero-returning')
        const ctaNew = document.getElementById('cta-new')
        if (heroNew) heroNew.classList.remove('hidden')
        if (heroReturning) heroReturning.classList.add('hidden')
        if (ctaNew) ctaNew.classList.remove('hidden')
      }
    })
  }).catch(() => {
    // Firebase failed to load — leave onboarding hero visible (safe default)
  })
</script>
