---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import ContentRow from '@/components/blog/ContentRow'
import BlogCard from '@/components/blog/BlogCard'
import ChatWidget from '@/components/chat/ChatWidget'
import OnboardingGateWrapper from '@/components/auth/OnboardingGateWrapper'
import { getOrganForCategory, getTodaysOrgan } from '@/lib/content/organs'
import { HABITS } from '@/lib/content/habits'
export const prerender = false

let blogs: any[] = []
try {
  const res = await fetch('https://9vhd0onw23.execute-api.ap-south-1.amazonaws.com/published-blogs')
  if (res.ok) {
    blogs = (await res.json()) as any[]
    blogs.sort((a: any, b: any) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
  }
} catch {}

const heroBlog = blogs[0] || null
const remainingBlogs = blogs.slice(1, 7)
const linkedOrgan = heroBlog ? getOrganForCategory(heroBlog.category || '') || getTodaysOrgan() : getTodaysOrgan()
const linkedHabit = HABITS.find(h => h.key === linkedOrgan.relatedHabit) || HABITS[0]
const heroDate = heroBlog?.createdAt
  ? new Date(heroBlog.createdAt).toLocaleDateString('en-IN', { month: 'long', day: 'numeric', year: 'numeric' })
  : ''
---

<BaseLayout title="SKIDS Parent" description="Track your child's milestones, vaccinations, growth, and health. Ask Dr. SKIDS, India's AI paediatrician, anytime.">
  <Navbar />
  <main>
    <OnboardingGateWrapper client:load />

    <!-- HERO A: Daily content — hidden by default, shown to logged-in users via JS -->
    <div id="hero-returning" class="hidden">
      {heroBlog ? (
        <section class="relative w-full h-[56vw] min-h-[340px] max-h-[600px] sm:h-[65vh] overflow-hidden">
          <img src={heroBlog.thumbnail} alt="" class="absolute inset-0 w-full h-full object-cover object-center" loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent" />
          <div class="absolute inset-0 bg-gradient-to-r from-black/50 via-transparent to-transparent" />
          <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-10 max-w-3xl">
            <span class="inline-flex px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm text-white text-xs font-semibold uppercase tracking-wider mb-3">
              {heroBlog.category || 'Health'}
            </span>
            <h1 class="text-2xl sm:text-4xl font-display font-extrabold text-white leading-tight mb-2 drop-shadow-lg">{heroBlog.title}</h1>
            <p class="text-white/60 text-sm mb-5">by {heroBlog.author || 'SKIDS'} · {heroDate}</p>
            <a href={`/blog/${heroBlog.blogId}`} class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white text-gray-900 font-semibold text-sm hover:bg-gray-100 transition-colors shadow-lg">
              Read Article
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </section>
      ) : (
        <section class="relative w-full h-[50vh] overflow-hidden bg-gradient-to-br from-gray-900 via-green-900 to-emerald-900">
          <div class="absolute inset-0 flex flex-col justify-end p-6 sm:p-10 max-w-3xl">
            <h1 class="text-3xl sm:text-5xl font-display font-extrabold text-white leading-tight mb-3">Raise Smart, Healthy <span class="text-green-400">S-Kids</span></h1>
            <a href="/blog" class="inline-flex self-start items-center gap-2 px-6 py-3 rounded-xl bg-white text-gray-900 font-semibold text-sm">Explore Articles</a>
          </div>
        </section>
      )}
    </div>

    <!-- HERO B: Onboarding value prop — shown by default, hidden to logged-in users via JS -->
    <div id="hero-new">
      <section class="relative bg-gradient-to-br from-gray-950 via-green-950 to-emerald-950 overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, #16a34a 0%, transparent 50%), radial-gradient(circle at 80% 20%, #059669 0%, transparent 40%)"></div>
        <div class="relative max-w-2xl mx-auto px-5 pt-12 pb-10 sm:pt-16 sm:pb-14 text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-500/20 border border-green-500/30 mb-5">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
            <span class="text-xs font-semibold text-green-300 uppercase tracking-wider">Free for Indian parents</span>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-display font-extrabold text-white leading-tight mb-4">
            Your child's complete<br /><span class="text-green-400">health record</span> — in your pocket
          </h1>
          <p class="text-base sm:text-lg text-white/70 leading-relaxed mb-8 max-w-lg mx-auto">
            From first steps to school — track milestones, vaccinations, growth, and habits. Ask Dr. SKIDS anything, anytime.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a href="/login" class="w-full sm:w-auto inline-flex items-center justify-center gap-2.5 px-7 py-4 rounded-2xl bg-green-500 hover:bg-green-400 text-white font-bold text-base transition-colors shadow-lg shadow-green-900/40">
              Start tracking — it's free
            </a>
            <a href="#how-it-works" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-7 py-4 rounded-2xl bg-white/10 hover:bg-white/15 text-white font-semibold text-base transition-colors border border-white/20">
              See how it works
            </a>
          </div>
          <p class="mt-5 text-xs text-white/40">Sign in with Google or your mobile number · No credit card needed</p>
        </div>
        <div class="relative max-w-2xl mx-auto px-5 pb-10">
          <div class="flex items-center gap-2.5 justify-center flex-wrap">
            {[{emoji:'🧒',label:'Milestone tracking'},{emoji:'💉',label:'Vaccination schedule'},{emoji:'📏',label:'Growth charts'},{emoji:'🩺',label:'Dr. SKIDS AI'},{emoji:'📓',label:'Observation journal'},{emoji:'🏃',label:'H.A.B.I.T.S. tracker'}].map(f => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/10 border border-white/15 text-white/80 text-xs font-medium">
                <span>{f.emoji}</span>{f.label}
              </span>
            ))}
          </div>
        </div>
      </section>

      <!-- How it works — only shown inside hero-new div -->
      <section id="how-it-works" class="px-5 py-12 sm:py-16 bg-white">
        <div class="max-w-2xl mx-auto">
          <div class="text-center mb-10">
            <h2 class="text-2xl sm:text-3xl font-display font-bold text-gray-900">Your child's health story, from day one</h2>
            <p class="mt-2 text-sm text-gray-500">Four steps. Takes 5 minutes to set up.</p>
          </div>
          <div class="space-y-4">
            <div class="flex gap-4 p-5 rounded-2xl bg-green-50 border border-green-100">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-green-500 flex items-center justify-center text-white font-bold text-sm">1</div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">Add your child</h3>
                <p class="text-sm text-gray-600 leading-relaxed">Enter name and date of birth. SKIDS instantly creates a personalised milestone wall — motor, cognitive, social, and language milestones matched to your child's exact age.</p>
              </div>
            </div>
            <div class="flex gap-4 p-5 rounded-2xl bg-blue-50 border border-blue-100">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-blue-500 flex items-center justify-center text-white font-bold text-sm">2</div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">Tell Dr. SKIDS your child's history</h3>
                <p class="text-sm text-gray-600 leading-relaxed">Chat with Dr. SKIDS to capture birth history, past illnesses, allergies, and family health background. This becomes the foundation of your child's health profile.</p>
              </div>
            </div>
            <div class="flex gap-4 p-5 rounded-2xl bg-purple-50 border border-purple-100">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-purple-500 flex items-center justify-center text-white font-bold text-sm">3</div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">Log observations as they happen</h3>
                <p class="text-sm text-gray-600 leading-relaxed">Note anything — a fever, a new word, a concern, a happy moment. Each observation links to Dr. SKIDS so you can ask questions right then.</p>
              </div>
            </div>
            <div class="flex gap-4 p-5 rounded-2xl bg-amber-50 border border-amber-100">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-amber-500 flex items-center justify-center text-white font-bold text-sm">4</div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">Never miss a screening</h3>
                <p class="text-sm text-gray-600 leading-relaxed">IAP vaccination schedule, vision checks, hearing, nutrition — SKIDS tracks what's due. Not just vaccines — head-to-toe screening reminders so nothing slips through.</p>
              </div>
            </div>
          </div>
          <div class="mt-8 text-center">
            <a href="/login" class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-gray-900 text-white font-bold text-sm hover:bg-gray-800 transition-colors">
              Create your child's profile
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>
      </section>
      <!-- Free Tier Value Section — Task 23.1 -->
      <section id="free-tier-value" class="px-5 py-12 sm:py-16 bg-green-50">
        <div class="max-w-2xl mx-auto">
          <div class="text-center mb-10">
            <h2 class="text-2xl sm:text-3xl font-display font-bold text-gray-900">What you get for free</h2>
            <p class="mt-2 text-sm text-gray-500">Real value from day one — no credit card needed.</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex gap-4 p-5 rounded-2xl bg-white border border-green-100 shadow-sm">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center text-xl">🩺</div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">20 AI questions per day</h3>
                <p class="text-sm text-gray-600 leading-relaxed">Get expert guidance on your child's health — answered with paediatric context, not generic advice.</p>
              </div>
            </div>
            <div class="flex gap-4 p-5 rounded-2xl bg-white border border-green-100 shadow-sm">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center text-xl">📈</div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">Health tracking</h3>
                <p class="text-sm text-gray-600 leading-relaxed">Monitor your child's development and milestones — from first steps to school, all in one place.</p>
              </div>
            </div>
            <div class="flex gap-4 p-5 rounded-2xl bg-white border border-green-100 shadow-sm">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-purple-100 flex items-center justify-center text-xl">👨‍👩‍👧</div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">Community access</h3>
                <p class="text-sm text-gray-600 leading-relaxed">Connect with other parents and share experiences — you're not alone on this journey.</p>
              </div>
            </div>
            <div class="flex gap-4 p-5 rounded-2xl bg-white border border-green-100 shadow-sm">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center text-xl">📄</div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">Basic PDF export</h3>
                <p class="text-sm text-gray-600 leading-relaxed">Download your child's health records — ready to share with any doctor, anytime.</p>
              </div>
            </div>
          </div>
          <div class="mt-8 text-center">
            <a href="/login" class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-green-500 hover:bg-green-400 text-white font-bold text-sm transition-colors shadow-lg shadow-green-900/20">
              Start for free
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Premium Benefits Section — Task 24.1 & 24.2 -->
      <section id="premium-value" class="px-5 py-12 sm:py-16 bg-gray-900">
        <div class="max-w-2xl mx-auto">
          <div class="text-center mb-10">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-500/20 border border-amber-500/30 mb-4">
              <span class="text-xs font-semibold text-amber-300 uppercase tracking-wider">✨ SKIDS Premium</span>
            </div>
            <h2 class="text-2xl sm:text-3xl font-display font-bold text-white">Sound familiar?</h2>
            <p class="mt-2 text-sm text-white/50">Premium is built around the problems parents actually face.</p>
          </div>
          <div class="space-y-3">
            <button
              class="premium-benefit-item w-full text-left flex gap-4 p-5 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors cursor-pointer"
              data-benefit="frequent_questions"
              aria-label="Learn about 100 AI answers per day"
            >
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-amber-500/20 flex items-center justify-center text-xl">💬</div>
              <div>
                <p class="text-sm text-amber-300 font-semibold mb-0.5">Have frequent questions?</p>
                <h3 class="font-bold text-white">Get 100 AI answers per day</h3>
                <p class="text-sm text-white/50 mt-1 leading-relaxed">Never hit a wall when you need guidance most.</p>
              </div>
            </button>
            <button
              class="premium-benefit-item w-full text-left flex gap-4 p-5 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors cursor-pointer"
              data-benefit="health_score_breakdown"
              aria-label="Learn about component score breakdown"
            >
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center text-xl">📊</div>
              <div>
                <p class="text-sm text-blue-300 font-semibold mb-0.5">Want to understand your child's health in detail?</p>
                <h3 class="font-bold text-white">Get component score breakdown</h3>
                <p class="text-sm text-white/50 mt-1 leading-relaxed">See exactly which areas need attention — not just an overall score.</p>
              </div>
            </button>
            <button
              class="premium-benefit-item w-full text-left flex gap-4 p-5 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors cursor-pointer"
              data-benefit="teleconsult_discount"
              aria-label="Learn about teleconsult discount"
            >
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center text-xl">🏥</div>
              <div>
                <p class="text-sm text-green-300 font-semibold mb-0.5">Need to book appointments?</p>
                <h3 class="font-bold text-white">Get teleconsult discount</h3>
                <p class="text-sm text-white/50 mt-1 leading-relaxed">Save on every consultation with SKIDS-partnered paediatricians.</p>
              </div>
            </button>
            <button
              class="premium-benefit-item w-full text-left flex gap-4 p-5 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors cursor-pointer"
              data-benefit="unlimited_profiles"
              aria-label="Learn about unlimited children profiles"
            >
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center text-xl">👶</div>
              <div>
                <p class="text-sm text-purple-300 font-semibold mb-0.5">Have multiple children?</p>
                <h3 class="font-bold text-white">Track unlimited profiles</h3>
                <p class="text-sm text-white/50 mt-1 leading-relaxed">Every child gets their own complete health record.</p>
              </div>
            </button>
          </div>
          <div class="mt-8 text-center">
            <a href="/login" class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-amber-500 hover:bg-amber-400 text-white font-bold text-sm transition-colors shadow-lg shadow-amber-900/30">
              Explore Premium
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Social Proof Section — Task 25.1 & 25.2 -->
      <section id="social-proof" class="px-5 py-12 sm:py-16 bg-white">
        <div class="max-w-2xl mx-auto">
          <div class="text-center mb-10">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-50 border border-green-200 mb-5">
              <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
              <span class="text-sm font-bold text-green-700">Join 10,000+ parents</span>
            </div>
            <h2 class="text-2xl sm:text-3xl font-display font-bold text-gray-900">Parents love SKIDS</h2>
            <p class="mt-2 text-sm text-gray-500">Real stories from families across India.</p>
          </div>

          <!-- Activity indicators -->
          <div class="flex flex-wrap justify-center gap-3 mb-10">
            <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-gray-50 border border-gray-200">
              <span class="text-base">🩺</span>
              <span class="text-sm font-medium text-gray-700">50,000+ AI questions answered</span>
            </div>
            <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-gray-50 border border-gray-200">
              <span class="text-base">👶</span>
              <span class="text-sm font-medium text-gray-700">15,000+ children tracked</span>
            </div>
            <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-gray-50 border border-gray-200">
              <span class="text-base">💬</span>
              <span class="text-sm font-medium text-gray-700">Active community of parents</span>
            </div>
          </div>

          <!-- Testimonials -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button
              class="social-proof-item text-left p-5 rounded-2xl bg-green-50 border border-green-100 hover:bg-green-100 transition-colors"
              data-story="vaccination_tracking"
              aria-label="Read Priya's story"
            >
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-full bg-green-200 flex items-center justify-center text-lg font-bold text-green-700">P</div>
                <div>
                  <p class="font-bold text-gray-900 text-sm">Priya M.</p>
                  <p class="text-xs text-gray-500">Mother of 2, Bengaluru</p>
                </div>
              </div>
              <p class="text-sm text-gray-700 leading-relaxed">"Dr. SKIDS helped me understand my son's vaccination schedule better than any pamphlet. I never miss a due date now."</p>
            </button>
            <button
              class="social-proof-item text-left p-5 rounded-2xl bg-blue-50 border border-blue-100 hover:bg-blue-100 transition-colors"
              data-story="milestone_tracking"
              aria-label="Read Rahul's story"
            >
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-full bg-blue-200 flex items-center justify-center text-lg font-bold text-blue-700">R</div>
                <div>
                  <p class="font-bold text-gray-900 text-sm">Rahul K.</p>
                  <p class="text-xs text-gray-500">Father of 1, Mumbai</p>
                </div>
              </div>
              <p class="text-sm text-gray-700 leading-relaxed">"The milestone tracking gave me peace of mind. When I had concerns, Dr. SKIDS gave me real answers — not just 'consult a doctor'."</p>
            </button>
            <button
              class="social-proof-item text-left p-5 rounded-2xl bg-purple-50 border border-purple-100 hover:bg-purple-100 transition-colors sm:col-span-2"
              data-story="community_support"
              aria-label="Read Ananya's story"
            >
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-full bg-purple-200 flex items-center justify-center text-lg font-bold text-purple-700">A</div>
                <div>
                  <p class="font-bold text-gray-900 text-sm">Ananya S.</p>
                  <p class="text-xs text-gray-500">Mother of 3, Delhi</p>
                </div>
              </div>
              <p class="text-sm text-gray-700 leading-relaxed">"Managing health records for three kids used to be chaos. SKIDS Premium keeps everything organised and the teleconsult discount has already paid for itself."</p>
            </button>
          </div>

          <div class="mt-8 text-center">
            <a href="/login" class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-gray-900 hover:bg-gray-800 text-white font-bold text-sm transition-colors">
              Join the community
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>
      </section>
    </div>
    <!-- end hero-new -->


    <!-- ORGAN IN FOCUS — always visible -->
    <section class="px-4 sm:px-6 py-6 sm:py-8">
      <div class="max-w-3xl mx-auto">
        <div class={`rounded-2xl overflow-hidden bg-gradient-to-br ${linkedOrgan.gradient} p-[2px]`}>
          <div class="rounded-[14px] bg-white p-6 sm:p-8">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xs font-bold text-purple-600 uppercase tracking-wider">Organ in Focus</span>
              <span class="text-xs text-gray-400">— linked to today's article</span>
            </div>
            <div class="flex items-start gap-5">
              <div class={`flex-shrink-0 w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-gradient-to-br ${linkedOrgan.gradient} flex items-center justify-center text-4xl sm:text-5xl shadow-lg`}>
                {linkedOrgan.emoji}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-xl sm:text-2xl font-display font-bold text-gray-900">{linkedOrgan.name}</h3>
