<style>
  .font-serif {
    font-family: 'DM Serif Display', Georgia, 'Times New Roman', serif;
  }

  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes scroll-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }
  .cloud-track { width: max-content; }
  .cloud-track-left { animation: scroll-left 45s linear infinite; }
  .cloud-track-right { animation: scroll-right 50s linear infinite; }
  .cloud-track:hover { animation-play-state: paused; }
</style>

<script>
  /* Scroll-triggered reveal animations */
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible')
          io.unobserve(e.target)
        }
      })
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  )
  document.querySelectorAll('.reveal, .img-reveal').forEach((el) => io.observe(el))
</script>
