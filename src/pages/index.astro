---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import ChatWidget from '@/components/chat/ChatWidget'
import OnboardingGateWrapper from '@/components/auth/OnboardingGateWrapper'
export const prerender = false

let blogs: any[] = []
try {
  const res = await fetch('https://9vhd0onw23.execute-api.ap-south-1.amazonaws.com/published-blogs')
  if (res.ok) {
    blogs = (await res.json()) as any[]
    blogs.sort((a: any, b: any) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
  }
} catch {}

const heroBlog = blogs[0] || null
const secondaryBlogs = blogs.slice(1, 5)
const heroDate = heroBlog?.createdAt
  ? new Date(heroBlog.createdAt).toLocaleDateString('en-IN', { month: 'long', day: 'numeric' })
  : ''

/* Pick blog thumbnails for section backgrounds (India/GCC context) */
const bgImages = blogs.filter((b: any) => b.thumbnail).slice(5, 9)
const wonderBg = bgImages[0]?.thumbnail || ''
const growBg = bgImages[1]?.thumbnail || ''
const practiceBg = bgImages[2]?.thumbnail || ''
const coNurtureBg = bgImages[3]?.thumbnail || ''

const categoryColors: Record<string, string> = {
  'Mental Health': 'bg-purple-50 text-purple-700',
  'Parental Guidance': 'bg-pink-50 text-pink-700',
  'Physical Health': 'bg-green-50 text-green-700',
  'Nutrition & Diet': 'bg-orange-50 text-orange-700',
  'Kids Vision': 'bg-amber-50 text-amber-700',
  'Wellness': 'bg-teal-50 text-teal-700',
  'Child Development': 'bg-blue-50 text-blue-700',
}

/* Condition cloud — parent-language terms */
const conditionCloudRow1 = [
  'speech delay', 'not eating well', 'screen time', 'bedwetting',
  'can\'t sit still', 'reading struggles', 'always tired', 'picky eater',
  'frequent tantrums', 'not talking yet', 'toe walking', 'night terrors',
  'won\'t make eye contact', 'teeth grinding', 'mouth breathing',
]
const conditionCloudRow2 = [
  'short for age', 'squinting at TV', 'ear infections', 'stammering',
  'iron deficiency', 'obesity', 'skin rashes', 'allergies',
  'not walking yet', 'head banging', 'thumb sucking', 'snoring',
  'poor handwriting', 'wetting pants at school', 'afraid of everything',
]

/* Parent confessions */
const parentStories = [
  { quote: "I thought Aarav was just lazy. Turns out he couldn't see the board.", condition: 'vision', color: 'text-amber-600', bgColor: 'bg-amber-50' },
  { quote: "She wasn't being difficult at meals. She was anemic.", condition: 'anemia', color: 'text-red-500', bgColor: 'bg-red-50' },
  { quote: "We blamed the tablet. His speech delay had nothing to do with screens.", condition: 'speech delay', color: 'text-blue-600', bgColor: 'bg-blue-50' },
  { quote: "Everyone said he'd grow out of it. He didn't. Early therapy changed everything.", condition: 'development', color: 'text-purple-600', bgColor: 'bg-purple-50' },
  { quote: "I confused her dyslexia for laziness. For two years.", condition: 'dyslexia', color: 'text-green-700', bgColor: 'bg-green-50' },
]
---

<BaseLayout
  title="SKIDS Parent"
  description="Where parents and pediatricians care for children together. Daily insights, developmental guidance, and the intelligence your child deserves."
>
  <Navbar />
  <main class="overflow-hidden">
    <OnboardingGateWrapper client:load />


    <!-- ═══════════════════════════════════════════════════
         1. ARTICLES HERO — The magazine cover.
         ═══════════════════════════════════════════════════ -->
    <section class="bg-white pt-6 sm:pt-10 pb-10 sm:pb-14">
      <div class="max-w-5xl mx-auto px-5 sm:px-8">
        <div class="flex items-end justify-between mb-6">
          <div>
            <p class="text-xs font-semibold text-green-600 uppercase tracking-widest mb-1">Today on SKIDS</p>
            <h1 class="font-serif text-2xl sm:text-3xl text-gray-900 tracking-tight">
              What every parent should know
            </h1>
          </div>
          <a href="/blog" class="hidden sm:inline-flex text-sm font-medium text-green-600 hover:text-green-700 items-center gap-1">
            All articles <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <!-- Search bar -->
        <form action="/blog" method="get" class="relative max-w-xl mb-7">
          <input
            type="text"
            name="q"
            placeholder="Ask anything — iron deficiency, bedwetting, ADHD signs..."
            class="w-full pl-12 pr-4 py-3.5 rounded-full border border-gray-200 bg-gray-50/60 text-[0.95rem] text-gray-700 placeholder:text-gray-400 focus:outline-none focus:border-green-400 focus:bg-white focus:ring-2 focus:ring-green-100 transition-all"
          />
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </form>

        <!-- Featured articles grid -->
        {heroBlog ? (
          <div class="grid md:grid-cols-5 gap-5">
            <a href={`/blog/${heroBlog.blogId}`} class="md:col-span-3 group block">
              <div class="relative aspect-[4/3] rounded-2xl overflow-hidden">
                <img src={heroBlog.thumbnail} alt={heroBlog.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-700" loading="eager" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent" />
                <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8">
                  <span class={`inline-flex text-[10px] font-semibold px-2.5 py-1 rounded-full uppercase tracking-wider mb-3 ${categoryColors[heroBlog.category] || 'bg-white/20 text-white'}`}>
                    {heroBlog.category || 'Health'}
                  </span>
                  <h2 class="text-xl sm:text-2xl lg:text-[1.75rem] font-serif text-white leading-snug mb-2">
                    {heroBlog.title}
                  </h2>
                  <p class="text-white/50 text-sm">{heroBlog.author || 'SKIDS'} &middot; {heroDate}</p>
                </div>
              </div>
            </a>
            <div class="md:col-span-2 flex flex-row md:flex-col gap-4 overflow-x-auto md:overflow-visible no-scrollbar -mx-5 px-5 md:mx-0 md:px-0 pb-2 md:pb-0">
              {secondaryBlogs.map((blog: any) => (
                <a href={`/blog/${blog.blogId}`} class="group flex-shrink-0 w-[70vw] sm:w-[45vw] md:w-full flex md:flex-row flex-col gap-3">
                  <div class="aspect-[16/10] md:aspect-square md:w-24 rounded-xl overflow-hidden flex-shrink-0">
                    <img src={blog.thumbnail} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  </div>
                  <div class="flex-1 min-w-0 py-1">
                    <span class={`text-[10px] font-semibold uppercase tracking-wider ${(categoryColors[blog.category] || 'text-gray-400').split(' ').pop()}`}>
                      {blog.category}
                    </span>
                    <h3 class="text-[0.9rem] font-semibold text-gray-900 leading-snug line-clamp-2 mt-1">{blog.title}</h3>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <div class="text-center py-16">
            <h2 class="text-2xl font-serif text-gray-900 mb-3">New articles every day.</h2>
            <p class="text-gray-400 mb-6">Evidence-based guidance on child health, nutrition, and development.</p>
            <a href="/blog" class="text-green-600 font-semibold text-sm hover:text-green-700">Browse articles &rarr;</a>
          </div>
        )}
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         2. THE WONDER — Full-bleed image + awakening copy.
         "Your child's body is doing incredible things."
         ═══════════════════════════════════════════════════ -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0">
        <img
          src={wonderBg}
          alt=""
          class="w-full h-full object-cover img-reveal"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-black/30"></div>
      </div>

      <div class="relative max-w-5xl mx-auto px-5 sm:px-8 py-24 sm:py-36">
        <div class="max-w-xl">
          <h2 class="reveal font-serif text-[clamp(1.8rem,4.5vw,3rem)] leading-[1.1] tracking-tight text-white">
            Your child's body is doing<br />
            incredible things right now.
          </h2>
          <div class="mt-8 space-y-4 reveal reveal-delay-1">
            <p class="text-white/80 text-lg leading-relaxed">
              Their brain is forming one million new connections every second.
              Their gut is building an immune system that will protect them for life.
              Their eyes are learning to track, focus, and make sense of the world.
            </p>
            <p class="text-white/60 text-lg leading-relaxed">
              Most parents never learn this. Not because they don't care
              &mdash; because nobody tells them.
            </p>
          </div>
          <a href="/discover" class="reveal reveal-delay-2 inline-flex items-center gap-2 mt-10 px-7 py-3.5 rounded-full bg-white text-gray-900 font-semibold text-sm hover:bg-green-50 transition-colors">
            Explore how your child grows
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         3. CONDITION CLOUD — What hides in plain sight.
         ═══════════════════════════════════════════════════ -->
    <section class="py-14 sm:py-20 section-warm overflow-hidden">
      <div class="max-w-5xl mx-auto px-5 sm:px-8 mb-8">
        <h2 class="reveal font-serif text-[clamp(2rem,4.5vw,3rem)] leading-[1.08] tracking-tight text-gray-900">
          But some things hide<br class="hidden sm:block" />
          in plain sight.
        </h2>
        <p class="reveal reveal-delay-1 mt-3 text-lg text-gray-400 max-w-lg">
          They look like laziness, shyness, fussiness, or "just a phase."
        </p>
      </div>

      <div class="relative">
        <div class="cloud-track cloud-track-left flex gap-3 py-2">
          {[...conditionCloudRow1, ...conditionCloudRow1].map((term) => (
            <a href={`/blog?q=${encodeURIComponent(term)}`} class="flex-shrink-0 px-4 py-2 rounded-full border border-gray-200 bg-white text-sm text-gray-600 hover:border-green-400 hover:text-green-700 hover:bg-green-50 transition-all cursor-pointer whitespace-nowrap">
              {term}
            </a>
          ))}
        </div>
        <div class="cloud-track cloud-track-right flex gap-3 py-2 mt-2">
          {[...conditionCloudRow2, ...conditionCloudRow2].map((term) => (
            <a href={`/blog?q=${encodeURIComponent(term)}`} class="flex-shrink-0 px-4 py-2 rounded-full border border-gray-200 bg-white text-sm text-gray-600 hover:border-green-400 hover:text-green-700 hover:bg-green-50 transition-all cursor-pointer whitespace-nowrap">
              {term}
            </a>
          ))}
        </div>
        <div class="absolute inset-y-0 left-0 w-16 sm:w-24 bg-gradient-to-r from-[var(--color-warm-bg)] to-transparent z-10 pointer-events-none"></div>
        <div class="absolute inset-y-0 right-0 w-16 sm:w-24 bg-gradient-to-l from-[var(--color-warm-bg)] to-transparent z-10 pointer-events-none"></div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         4. PARENT CONFESSIONS — Real voices, real moments.
         ═══════════════════════════════════════════════════ -->
    <section class="py-14 sm:py-20 bg-white">
      <div class="max-w-5xl mx-auto px-5 sm:px-8">
        <p class="reveal text-xs font-semibold text-gray-400 uppercase tracking-widest mb-8">What parents told us</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
          {parentStories.map((story, i) => (
            <a href={`/blog?q=${encodeURIComponent(story.condition)}`} class={`reveal reveal-delay-${Math.min(i, 3)} group block rounded-2xl p-6 bg-gray-50/80 border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all`}>
              <div class={`w-8 h-8 rounded-full ${story.bgColor} flex items-center justify-center mb-4`}>
                <svg class={`w-4 h-4 ${story.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
                </svg>
              </div>
              <p class="text-gray-900 text-[0.95rem] leading-snug font-medium italic">
                "{story.quote}"
              </p>
              <p class={`text-xs font-semibold mt-3 ${story.color} uppercase tracking-wider group-hover:underline`}>
                Read more &rarr;
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         5. THE NUMBERS — Conditions that hide in childhood.
         ═══════════════════════════════════════════════════ -->
    <section class="py-24 sm:py-32 section-warm">
      <div class="max-w-5xl mx-auto px-5 sm:px-8">
        <h2 class="reveal font-serif text-[clamp(1.8rem,4vw,2.75rem)] leading-[1.1] tracking-tight text-gray-900 mb-16 sm:mb-24 max-w-3xl">
          These are the things that get missed.
        </h2>

        <div class="reveal md:grid md:grid-cols-2 md:gap-16 items-start mb-20 sm:mb-28">
          <div>
            <span class="font-serif text-[clamp(3.5rem,8vw,6rem)] leading-none text-amber-500/20 block">1 in 4</span>
          </div>
          <div class="mt-4 md:mt-6">
            <p class="text-xl sm:text-2xl font-serif text-gray-900 leading-snug mb-4">
              children have an undetected vision problem.
            </p>
            <p class="text-gray-500 leading-relaxed">
              The teacher says "not paying attention." The parent thinks "shy."
              A 5-minute screening would have caught it.
              The child just needed glasses.
            </p>
          </div>
        </div>

        <div class="reveal md:grid md:grid-cols-2 md:gap-16 items-start mb-20 sm:mb-28">
          <div>
            <span class="font-serif text-[clamp(3.5rem,8vw,6rem)] leading-none text-red-400/20 block">4 in 10</span>
          </div>
          <div class="mt-4 md:mt-6">
            <p class="text-xl sm:text-2xl font-serif text-gray-900 leading-snug mb-4">
              Indian children are anemic. Most look perfectly healthy.
            </p>
            <p class="text-gray-500 leading-relaxed">
              No visible symptoms. No complaints. Just a child whose brain
              is quietly missing the iron it needs to develop.
              A blood test at the right age catches it every time.
            </p>
          </div>
        </div>

        <div class="reveal md:grid md:grid-cols-2 md:gap-16 items-start">
          <div>
            <span class="font-serif text-[clamp(3.5rem,8vw,6rem)] leading-none text-green-500/20 block">80%</span>
          </div>
          <div class="mt-4 md:mt-6">
            <p class="text-xl sm:text-2xl font-serif text-gray-900 leading-snug mb-4">
              of brain development happens before age three.
            </p>
            <p class="text-gray-500 leading-relaxed">
              Most developmental screenings start after five.
              Two years of critical window, gone.
              The children who get early support aren't luckier &mdash;
              their parents just knew sooner.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         6. KNOW + DO — The brand bridge.
         Two paths: understand the body, then put it into practice.
         ═══════════════════════════════════════════════════ -->
    <section class="py-24 sm:py-32 bg-white">
      <div class="max-w-5xl mx-auto px-5 sm:px-8">
        <div class="reveal text-center max-w-2xl mx-auto mb-16 sm:mb-20">
          <h2 class="font-serif text-[clamp(2rem,5vw,3.25rem)] leading-[1.08] tracking-tight text-gray-900">
            Knowing is the first step.<br />
            Doing is everything.
          </h2>
          <p class="mt-5 text-lg text-gray-400 leading-relaxed">
            SKIDS gives you both. Understand what's happening inside your child's body,
            then practice six daily habits backed by neuroscience.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 sm:gap-8">
          <!-- GROW card -->
          <a href="/discover" class="reveal group relative block rounded-3xl overflow-hidden aspect-[4/3] sm:aspect-[3/2]">
            <img
              src={growBg}
              alt=""
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-7 sm:p-9">
              <p class="text-green-300 text-xs font-semibold uppercase tracking-widest mb-2">Grow</p>
              <h3 class="font-serif text-2xl sm:text-3xl text-white leading-tight mb-2">
                How your child's<br />body actually works
              </h3>
              <p class="text-white/60 text-sm leading-relaxed max-w-xs">
                16 systems. From the brain wiring itself to the gut building immunity. Interactive, visual, made for parents.
              </p>
              <span class="inline-flex items-center gap-1.5 mt-4 text-white text-sm font-medium group-hover:gap-2.5 transition-all">
                Explore
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </a>

          <!-- PRACTICE card -->
          <a href="/habits" class="reveal reveal-delay-1 group relative block rounded-3xl overflow-hidden aspect-[4/3] sm:aspect-[3/2]">
            <img
              src={practiceBg}
              alt=""
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-7 sm:p-9">
              <p class="text-amber-300 text-xs font-semibold uppercase tracking-widest mb-2">Practice</p>
              <h3 class="font-serif text-2xl sm:text-3xl text-white leading-tight mb-2">
                Six daily habits that<br />shape everything
              </h3>
              <p class="text-white/60 text-sm leading-relaxed max-w-xs">
                H.A.B.I.T.S. Nutrition, movement, stress, mindset, routine, sleep. Plus 6 workshop programs for parents and students.
              </p>
              <span class="inline-flex items-center gap-1.5 mt-4 text-white text-sm font-medium group-hover:gap-2.5 transition-all">
                Start practicing
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </a>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         7. CO-NURTURING — The philosophy, with image.
         ═══════════════════════════════════════════════════ -->
    <section class="relative overflow-hidden">
      <div class="md:grid md:grid-cols-2 min-h-[480px] sm:min-h-[560px]">
        <!-- Image half -->
        <div class="relative h-64 sm:h-80 md:h-auto">
          <img
            src={coNurtureBg}
            alt=""
            class="absolute inset-0 w-full h-full object-cover img-reveal"
            loading="lazy"
          />
        </div>

        <!-- Copy half -->
        <div class="bg-white flex items-center">
          <div class="px-8 sm:px-12 lg:px-16 py-16 sm:py-20 max-w-lg">
            <h2 class="reveal font-serif text-[clamp(1.8rem,3.5vw,2.75rem)] leading-[1.08] tracking-tight text-gray-900">
              Between checkups,<br />
              childhood happens.
            </h2>
            <div class="reveal reveal-delay-1 mt-6 space-y-4">
              <p class="text-gray-500 text-lg leading-relaxed">
                The way she holds her spoon. How he squints at the TV from close.
                Whether she's been more tired this month. These aren't symptoms.
                They're signals &mdash; and only a parent sees them every day.
              </p>
              <p class="text-gray-500 text-lg leading-relaxed">
                Your pediatrician has the training to know what they mean.
                But they need to see what you see.
              </p>
              <p class="text-gray-900 text-lg leading-relaxed font-medium">
                SKIDS connects every parent observation to your child's clinical picture &mdash;
                so your pediatrician walks in prepared, and nothing gets missed.
              </p>
            </div>
            <p class="reveal reveal-delay-2 mt-10 font-serif text-xl sm:text-2xl text-gray-900 tracking-tight">
              We call this co-nurturing.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         8. PERSONA — Meera's story, with emotion.
         ═══════════════════════════════════════════════════ -->
    <section class="py-24 sm:py-32 section-warm">
      <div class="max-w-4xl mx-auto px-5 sm:px-8">
        <p class="reveal text-sm font-medium text-gray-400 uppercase tracking-widest mb-4">A real story</p>
        <h2 class="reveal font-serif text-2xl sm:text-3xl text-gray-900 tracking-tight mb-12 sm:mb-16">
          Meera almost waited too long.
        </h2>

        <div class="space-y-8 sm:space-y-12 border-l-2 border-gray-200 pl-8 sm:pl-12 relative">
          <div class="reveal relative">
            <div class="absolute -left-[calc(2rem+5px)] sm:-left-[calc(3rem+5px)] w-3 h-3 rounded-full bg-green-500 border-2 border-white"></div>
            <p class="text-xs font-semibold text-green-600 uppercase tracking-wider mb-2">Morning</p>
            <p class="text-gray-900 font-medium text-lg">Her 2-year-old isn't babbling as much as her older one did.</p>
            <p class="text-gray-400 mt-1.5 leading-relaxed">She logs it on SKIDS in 10 seconds. Not a clinic visit. Just a note.</p>
          </div>

          <div class="reveal relative">
            <div class="absolute -left-[calc(2rem+5px)] sm:-left-[calc(3rem+5px)] w-3 h-3 rounded-full bg-amber-500 border-2 border-white"></div>
            <p class="text-xs font-semibold text-amber-600 uppercase tracking-wider mb-2">That evening</p>
            <p class="text-gray-900 font-medium text-lg">SKIDS connects the note with two earlier observations she'd forgotten.</p>
