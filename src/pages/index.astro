---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import ContentRow from '@/components/blog/ContentRow'
import BlogCard from '@/components/blog/BlogCard'
import ChatWidget from '@/components/chat/ChatWidget'
import { getOrganForCategory, getTodaysOrgan } from '@/lib/content/organs'
import { HABITS } from '@/lib/content/habits'
export const prerender = true

// ─── Fetch & sort blogs (latest first by createdAt) ───
let blogs: any[] = []
try {
  const res = await fetch('https://9vhd0onw23.execute-api.ap-south-1.amazonaws.com/published-blogs')
  if (res.ok) {
    blogs = (await res.json()) as any[]
    blogs.sort((a: any, b: any) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
  }
} catch {
  // Fallback: empty
}

// ─── TODAY'S BLOG → ORGAN → HABIT (linked chain) ───
const heroBlog = blogs[0] || null
const remainingBlogs = blogs.slice(1) // everything except hero, no repeats

// Organ linked to hero blog's category
const linkedOrgan = heroBlog
  ? getOrganForCategory(heroBlog.category || '') || getTodaysOrgan()
  : getTodaysOrgan()

// Habit linked to the organ's relatedHabit field
const linkedHabit = HABITS.find((h) => h.key === linkedOrgan.relatedHabit) || HABITS[0]

// Hero blog date
const heroDate = heroBlog?.createdAt
  ? new Date(heroBlog.createdAt).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
  : ''

// ─── CONTEXTUAL META-PROMPTS (from today's linked chain) ───
const organName = linkedOrgan.name.toLowerCase()
const habitName = linkedHabit.name.toLowerCase()
const metaPrompts = {
  digDeeper: {
    emoji: '📰',
    label: 'Dig Deeper',
    sublabel: `Today's focus: ${linkedOrgan.name}`,
    prompt: `How does ${organName} development affect my child's daily life?`,
  },
  milestone: {
    emoji: '🧒',
    label: 'Milestone Check',
    sublabel: 'Personalized for your child',
    prompt: `Is my child's ${organName} development on track for their age?`,
  },
  healthNote: {
    emoji: '📋',
    label: 'Health Note',
    sublabel: 'Build your child\'s timeline',
    prompt: `I want to note something about my child's ${habitName} routine`,
  },
}
---

<BaseLayout title="SKIDS Parent" description="The place where today's parents come to raise smart, healthy S-Kids. Evidence-based child health, AI-powered insights, and personalized care.">
  <Navbar />

  <main>
    <!-- ═══════════════════════════════════════
         HERO — Today's Latest Blog (ONE, not carousel)
         ═══════════════════════════════════════ -->
    {heroBlog ? (
      <section class="relative w-full h-[70vh] sm:h-[60vh] overflow-hidden">
        <!-- Blog image -->
        <img
          src={heroBlog.thumbnail}
          alt=""
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
        />

        <!-- Gradient overlays -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-black/5" />
        <div class="absolute inset-0 bg-gradient-to-r from-black/50 via-transparent to-transparent" />

        <!-- Content -->
        <div class="absolute inset-0 flex flex-col justify-end p-6 sm:p-10 lg:p-16 max-w-3xl">
          <span class="inline-flex self-start px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm text-white text-xs font-semibold uppercase tracking-wider mb-3">
            {heroBlog.category || 'Health'}
          </span>

          <h1 class="text-2xl sm:text-4xl lg:text-5xl font-display font-extrabold text-white leading-tight mb-3 drop-shadow-lg">
            {heroBlog.title}
          </h1>

          <p class="text-white/60 text-sm mb-5">
            by {heroBlog.author || 'SKIDS Team'} · {heroDate}
          </p>

          <a
            href={`/blog/${heroBlog.blogId}`}
            target="_blank"
            rel="noopener"
            class="inline-flex self-start items-center gap-2 px-6 py-3 rounded-xl bg-white text-gray-900 font-semibold text-sm hover:bg-gray-100 transition-colors shadow-lg"
          >
            Read Article
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </section>
    ) : (
      <!-- Fallback hero if no blogs -->
      <section class="relative w-full h-[60vh] overflow-hidden bg-gradient-to-br from-gray-900 via-green-900 to-emerald-900">
        <div class="absolute inset-0 flex flex-col justify-end p-6 sm:p-10 lg:p-16 max-w-3xl">
          <h1 class="text-3xl sm:text-5xl font-display font-extrabold text-white leading-tight mb-3">
            Raise Smart, Healthy <span class="text-green-400">S-Kids</span>
          </h1>
          <p class="text-white/60 text-base mb-5">Science-backed insights, AI-powered tools, and expert care.</p>
          <a href="/blog" class="inline-flex self-start items-center gap-2 px-6 py-3 rounded-xl bg-white text-gray-900 font-semibold text-sm">
            Explore Articles
          </a>
        </div>
      </section>
    )}

    <!-- Dark-to-warm transition -->
    <div class="hero-to-content"></div>

    <!-- ═══════════════════════════════════════
         ORGAN IN FOCUS — Big, linked to hero blog
         ═══════════════════════════════════════ -->
    <section class="px-4 sm:px-6 lg:px-10 py-6 sm:py-8">
      <div class="max-w-3xl mx-auto">
        <div class={`rounded-2xl overflow-hidden bg-gradient-to-br ${linkedOrgan.gradient} p-[2px]`}>
          <div class="rounded-[14px] bg-white p-6 sm:p-8">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xs font-bold text-purple-600 uppercase tracking-wider">Organ in Focus</span>
              <span class="text-xs text-gray-400">— linked to today's article</span>
            </div>

            <div class="flex items-start gap-5">
              <div class={`flex-shrink-0 w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-gradient-to-br ${linkedOrgan.gradient} flex items-center justify-center text-4xl sm:text-5xl shadow-lg`}>
                {linkedOrgan.emoji}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-xl sm:text-2xl font-display font-bold text-gray-900">
                  {linkedOrgan.name}
                </h3>
                <p class="mt-2 text-sm text-gray-600 leading-relaxed">
                  {linkedOrgan.description}
                </p>
                <p class="mt-3 text-xs text-purple-600 font-medium italic">
                  "{linkedOrgan.wonderFact}"
                </p>
              </div>
            </div>

            <div class="mt-6 flex items-center justify-between">
              <a
                href={`/discover/${linkedOrgan.slug}`}
                class="inline-flex items-center gap-1.5 text-sm font-semibold text-green-600 hover:text-green-700 transition-colors"
              >
                Explore {linkedOrgan.name}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
              <a
                href="/discover"
                class="text-xs font-medium text-gray-400 hover:text-gray-600 transition-colors"
              >
                All 16 organs →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         TODAY'S HABIT — Big dark card, linked to organ
         ═══════════════════════════════════════ -->
    <section class="px-4 sm:px-6 lg:px-10 py-4 sm:py-6">
      <div class="max-w-3xl mx-auto">
        <div class="rounded-2xl bg-gradient-to-br from-gray-900 to-gray-800 p-6 sm:p-8 text-white overflow-hidden relative">
          <!-- Background letter -->
          <div class="absolute top-2 right-4 text-[8rem] sm:text-[10rem] font-display font-black text-white/[0.03] leading-none select-none">
            {linkedHabit.letter}
          </div>

          <div class="relative">
            <!-- H.A.B.I.T.S letters -->
            <div class="flex items-center gap-2 mb-5">
              {HABITS.map((h) => (
                <span
                  class:list={[
                    'habit-letter',
                    h.bgColor,
                    h.key === linkedHabit.key ? 'habit-letter-active' : 'opacity-30',
                  ]}
                >
                  {h.letter}
                </span>
              ))}
            </div>

            <div class="flex items-center gap-2 mb-1">
              <span class="text-xl">{linkedHabit.emoji}</span>
              <span class="text-xs font-bold text-green-400 uppercase tracking-wider">Today's Habit</span>
            </div>
            <h3 class="text-xl sm:text-2xl font-display font-bold">{linkedHabit.name}</h3>
            <p class="mt-1 text-sm text-white/50 font-medium">{linkedHabit.tagline}</p>

            <p class="mt-4 text-sm text-white/80 leading-relaxed max-w-lg">
              {linkedHabit.description}
            </p>

            <div class="mt-5 p-3.5 rounded-xl bg-white/10 backdrop-blur-sm border border-white/10">
              <p class="text-sm text-white/90 font-medium">
                💡 {linkedHabit.tip}
              </p>
            </div>

            <div class="mt-5 flex items-center justify-between">
              <a
                href="/discover"
                class="text-xs font-medium text-green-400 hover:text-green-300 flex items-center gap-1"
              >
                All 6 habits →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         DR. SKIDS — Contextual Health Companion
         Meta-prompts tied to today's blog/organ/habit
         ═══════════════════════════════════════ -->
    <section class="px-4 sm:px-6 lg:px-10 py-6 sm:py-8">
      <div class="max-w-3xl mx-auto">
        <div class="rounded-2xl bg-gradient-to-br from-green-600 via-emerald-600 to-teal-700 p-6 sm:p-8 text-white relative overflow-hidden">
          <!-- Background pattern -->
          <div class="absolute top-0 right-0 w-48 h-48 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/4"></div>
          <div class="absolute bottom-0 left-0 w-32 h-32 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/4"></div>

          <div class="relative">
            <!-- Header -->
            <div class="flex items-center gap-3 mb-2">
              <div class="w-11 h-11 rounded-xl bg-white/20 backdrop-blur-sm flex items-center justify-center text-xl">
                🩺
              </div>
              <div>
                <h3 class="text-lg font-display font-bold">Dr. SKIDS</h3>
                <p class="text-[11px] text-white/60">Your child's health companion</p>
              </div>
            </div>

            <p class="text-xs text-white/70 mb-5 leading-relaxed">
              Every question builds your child's health timeline. Ask, track, and grow together.
            </p>

            <!-- Contextual Prompt Cards -->
            <div class="space-y-2.5 mb-5">
              <!-- Dig Deeper — tied to today's content -->
              <button
                class="quick-q-pill w-full text-left p-3.5 rounded-xl bg-white/10 backdrop-blur-sm border border-white/15 hover:bg-white/20 transition-all cursor-pointer group"
                data-question={metaPrompts.digDeeper.prompt}
              >
                <div class="flex items-start gap-3">
                  <span class="text-lg mt-0.5">{metaPrompts.digDeeper.emoji}</span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-0.5">
                      <span class="text-xs font-bold text-white/90 uppercase tracking-wider">{metaPrompts.digDeeper.label}</span>
                      <span class="text-[10px] text-white/40">{metaPrompts.digDeeper.sublabel}</span>
                    </div>
                    <p class="text-sm text-white/80 leading-snug group-hover:text-white transition-colors">
                      "{metaPrompts.digDeeper.prompt}"
                    </p>
                  </div>
                  <svg class="w-4 h-4 text-white/30 group-hover:text-white/60 transition-colors flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </div>
              </button>

              <!-- Milestone Check — personalized nudge -->
              <button
                class="quick-q-pill w-full text-left p-3.5 rounded-xl bg-white/10 backdrop-blur-sm border border-white/15 hover:bg-white/20 transition-all cursor-pointer group"
                data-question={metaPrompts.milestone.prompt}
              >
                <div class="flex items-start gap-3">
                  <span class="text-lg mt-0.5">{metaPrompts.milestone.emoji}</span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-0.5">
                      <span class="text-xs font-bold text-white/90 uppercase tracking-wider">{metaPrompts.milestone.label}</span>
                      <span class="text-[10px] text-white/40">{metaPrompts.milestone.sublabel}</span>
                    </div>
                    <p class="text-sm text-white/80 leading-snug group-hover:text-white transition-colors">
                      "{metaPrompts.milestone.prompt}"
                    </p>
                  </div>
                  <svg class="w-4 h-4 text-white/30 group-hover:text-white/60 transition-colors flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </div>
              </button>

              <!-- Health Note — PHR builder -->
              <button
                class="quick-q-pill w-full text-left p-3.5 rounded-xl bg-white/10 backdrop-blur-sm border border-white/15 hover:bg-white/20 transition-all cursor-pointer group"
                data-question={metaPrompts.healthNote.prompt}
              >
                <div class="flex items-start gap-3">
                  <span class="text-lg mt-0.5">{metaPrompts.healthNote.emoji}</span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-0.5">
                      <span class="text-xs font-bold text-white/90 uppercase tracking-wider">{metaPrompts.healthNote.label}</span>
                      <span class="text-[10px] text-white/40">{metaPrompts.healthNote.sublabel}</span>
                    </div>
                    <p class="text-sm text-white/80 leading-snug group-hover:text-white transition-colors">
                      "{metaPrompts.healthNote.prompt}"
                    </p>
                  </div>
                  <svg class="w-4 h-4 text-white/30 group-hover:text-white/60 transition-colors flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </div>
              </button>
            </div>

            <!-- Main CTA -->
            <button
              id="open-chat-btn"
              class="w-full inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl bg-white text-green-700 font-bold text-sm hover:bg-green-50 transition-colors shadow-lg"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
              </svg>
              Start Your Child's Timeline
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         MORE ARTICLES — ONE carousel, no repeats
         ═══════════════════════════════════════ -->
    {remainingBlogs.length > 0 && (
      <ContentRow title="More Articles" emoji="📚" seeAllHref="/blog" client:visible>
        {remainingBlogs.map((blog: any) => (
          <BlogCard
            title={blog.title || 'Untitled'}
            thumbnail={blog.thumbnail}
            category={blog.category}
            author={blog.author}
            date={blog.createdAt}
            link={`/blog/${blog.blogId}`}
          />
        ))}
      </ContentRow>
    )}

    <!-- ═══════════════════════════════════════
         FINAL CTA
         ═══════════════════════════════════════ -->
    <section class="py-14 sm:py-20 bg-gray-900">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl sm:text-3xl font-display font-bold text-white">
          Every question builds your child's health story
        </h2>
        <p class="mt-3 text-sm text-gray-400 max-w-xl mx-auto">
          Like a timeline for health — milestone tracking, expert guidance, and a complete record that grows with your child.
        </p>
        <div class="mt-8">
          <a href="/timeline" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-2xl bg-white text-gray-900 font-bold text-sm hover:bg-gray-100 transition-colors shadow-lg">
            Start Your Child's Timeline
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
        <p class="mt-3 text-xs text-gray-500">No credit card required. Free blog + health tracking.</p>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Bottom spacer for mobile tab bar -->
  <div class="h-16 md:hidden"></div>

  <!-- Floating ChatWidget -->
  <ChatWidget client:idle />

  <!-- Mobile bottom tab bar -->
  <MobileTabBar />
</BaseLayout>

<script>
  // Wire the "Start Conversation" button to open ChatWidget
  document.getElementById('open-chat-btn')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-dr-skids'))
  })

  // Wire quick-question pills — open chat with that question pre-filled
  document.querySelectorAll('.quick-q-pill').forEach((pill) => {
    pill.addEventListener('click', () => {
      const question = (pill as HTMLElement).dataset.question || ''
      window.dispatchEvent(new CustomEvent('open-dr-skids', { detail: { question } }))
    })
  })
</script>
