---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'

// Static page — maximum SEO
export const prerender = true

// Fetch latest blogs for the landing page
let blogs: any[] = []
try {
  const res = await fetch('https://9vhd0onw23.execute-api.ap-south-1.amazonaws.com/published-blogs')
  if (res.ok) {
    const data = await res.json()
    blogs = (data as any[]).slice(0, 6)
  }
} catch {
  // Fallback: empty — will show skeleton
}

const organHighlights = [
  { slug: 'brain', emoji: '🧠', name: 'Brain & Mind', fact: '86 billion neurons forming 1 million new connections every second' },
  { slug: 'heart', emoji: '❤️', name: 'Heart & Blood', fact: 'Beats 100,000 times a day, pumping 2,000 gallons of blood' },
  { slug: 'eyes', emoji: '👁️', name: 'Vision & Sight', fact: '80% of learning happens through vision in the first 12 years' },
  { slug: 'ears', emoji: '👂', name: 'Hearing & Sound', fact: 'Language development depends on hearing — critical window: 0-3 years' },
  { slug: 'emotions', emoji: '💛', name: 'Emotional Health', fact: 'Children can identify 30+ emotions by age 5' },
  { slug: 'digestive', emoji: '🍎', name: 'Nutrition & Gut', fact: 'The gut produces 95% of your child\'s serotonin (happy hormone)' },
]

const d2cServices = [
  { icon: '🥗', name: 'NutreeAI Nutrition', desc: 'AI-powered meal plans personalized to your child\'s growth', badge: 'AI-Powered' },
  { icon: '🧠', name: 'Behavioral Assessment', desc: 'Screen for ADHD, autism, anxiety with standardized tools', badge: 'Clinical' },
  { icon: '😴', name: 'Sleep Program', desc: '4-week evidence-based sleep intervention for better rest', badge: 'New' },
  { icon: '🗣️', name: 'Speech Therapy', desc: 'Online sessions with certified speech-language pathologists', badge: 'Telehealth' },
  { icon: '👨‍👩‍👧', name: 'Parenting Coach', desc: 'Expert guidance for modern parenting challenges', badge: 'Popular' },
  { icon: '📊', name: 'Growth Tracking Pro', desc: 'WHO z-score monitoring with AI trend analysis', badge: 'AI-Powered' },
]

const stats = [
  { value: '32+', label: 'Health Modules' },
  { value: '113+', label: 'Conditions Screened' },
  { value: '50+', label: 'Daily Articles' },
  { value: '16', label: 'Organ Discoveries' },
]
---

<BaseLayout title="SKIDS Parent" description="The place where today's parents come to raise smart, healthy S-Kids. Evidence-based child health, AI-powered insights, and personalized care — all in one place.">
  <Navbar />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-green-50 via-white to-blue-50"></div>
      <div class="absolute top-20 right-10 w-72 h-72 bg-green-100 rounded-full blur-3xl opacity-40"></div>
      <div class="absolute bottom-10 left-10 w-60 h-60 bg-blue-100 rounded-full blur-3xl opacity-30"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-20 lg:pt-24 lg:pb-28">
        <div class="max-w-3xl mx-auto text-center">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-green-50 border border-green-200 mb-8">
            <span class="w-2 h-2 rounded-full bg-green-500 pulse-dot"></span>
            <span class="text-sm font-medium text-green-700">Evidence-based child health</span>
          </div>

          <!-- Headline -->
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-extrabold tracking-tight leading-[1.1]">
            Raise Smart,<br />
            Healthy <span class="gradient-text">S-Kids</span>
          </h1>

          <p class="mt-6 text-lg sm:text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed">
            The new way of parenting. Holistic care for your child's physical, mental, and social health — powered by science, AI, and love.
          </p>

          <!-- CTA -->
          <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/blog" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-2xl bg-gray-900 text-white font-semibold text-base hover:bg-gray-800 transition-all shadow-lg shadow-gray-900/10 hover:shadow-xl hover:shadow-gray-900/15">
              Explore Health Insights
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="/discover" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-2xl bg-white text-gray-700 font-semibold text-base border border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition-all">
              Discover Your Child's Body
            </a>
          </div>

          <!-- Stats -->
          <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-6">
            {stats.map((stat) => (
              <div class="text-center">
                <div class="text-2xl sm:text-3xl font-display font-bold text-gray-900">{stat.value}</div>
                <div class="mt-1 text-xs sm:text-sm text-gray-500">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Why SKIDS -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <span class="text-sm font-semibold text-green-600 uppercase tracking-wider">The SKIDS Philosophy</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold">Every child deserves to be a Super Kid</h2>
          <p class="mt-4 text-gray-500 text-lg">
            SKIDS takes a holistic approach — physical, mental, and social health — because a child is not just a body. Early detection + right intervention = limitless potential.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="p-8 rounded-2xl bg-gradient-to-br from-green-50 to-emerald-50 border border-green-100">
            <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center text-2xl mb-5">🔬</div>
            <h3 class="text-lg font-display font-bold text-gray-900">Evidence-Based</h3>
            <p class="mt-2 text-sm text-gray-600 leading-relaxed">
              Every recommendation backed by AAP, IAP, and Gulf pediatric guidelines. No guesswork, no old wives' tales.
            </p>
          </div>
          <div class="p-8 rounded-2xl bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-100">
            <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center text-2xl mb-5">🤖</div>
            <h3 class="text-lg font-display font-bold text-gray-900">AI-Powered</h3>
            <p class="mt-2 text-sm text-gray-600 leading-relaxed">
              24/7 Dr. SKIDS chatbot, AI nutrition analysis, smart milestone tracking, and personalized health insights.
            </p>
          </div>
          <div class="p-8 rounded-2xl bg-gradient-to-br from-purple-50 to-fuchsia-50 border border-purple-100">
            <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center text-2xl mb-5">❤️</div>
            <h3 class="text-lg font-display font-bold text-gray-900">Empathy-Driven</h3>
            <p class="mt-2 text-sm text-gray-600 leading-relaxed">
              Warm, supportive, never scary. We empower parents with knowledge, not anxiety. Your partner in raising S-Kids.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Organ Discovery Preview -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <span class="text-sm font-semibold text-purple-600 uppercase tracking-wider">Organ Discovery</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold">Discover the wonders inside your child</h2>
          <p class="mt-4 text-gray-500 text-lg">
            16 interactive journeys through your child's amazing body. Understand how each organ develops — and what you can do to nurture it.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {organHighlights.map((organ) => (
            <a href={`/discover/${organ.slug}`} class="group card-hover block p-6 rounded-2xl bg-white border border-gray-100 shadow-sm">
              <div class="flex items-start gap-4">
                <span class="text-3xl">{organ.emoji}</span>
                <div class="flex-1 min-w-0">
                  <h3 class="text-base font-display font-bold text-gray-900 group-hover:text-green-600 transition-colors">
                    {organ.name}
                  </h3>
                  <p class="mt-1.5 text-sm text-gray-500 leading-relaxed">{organ.fact}</p>
                </div>
              </div>
              <div class="mt-4 flex items-center gap-1 text-xs font-medium text-green-600">
                <span>Explore journey</span>
                <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>

        <div class="mt-10 text-center">
          <a href="/discover" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold text-gray-700 bg-white border border-gray-200 hover:border-gray-300 shadow-sm hover:shadow transition-all">
            View all 16 discoveries
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- PHR Section -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <span class="text-sm font-semibold text-blue-600 uppercase tracking-wider">Child Health Record</span>
            <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold">
              The best PHR for your child
            </h2>
            <p class="mt-4 text-gray-500 text-lg leading-relaxed">
              Your observations + screening data + pediatric reports — all in one timeline. Watch your child's health story unfold, backed by evidence and AI insights.
            </p>

            <div class="mt-8 space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg bg-green-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Track milestones as you see them</h4>
                  <p class="text-sm text-gray-500">Motor, cognitive, social, language — observe and record your child's growth</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Auto-import SKIDS screening data</h4>
                  <p class="text-sm text-gray-500">When your child is screened at school or clinic, reports appear automatically</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg bg-purple-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Upload any pediatric report</h4>
                  <p class="text-sm text-gray-500">AI extracts key findings from PDFs and images into your child's timeline</p>
                </div>
              </div>
            </div>
          </div>

          <!-- PHR Visual -->
          <div class="relative">
            <div class="rounded-2xl bg-gradient-to-br from-gray-50 to-gray-100 border border-gray-200 p-6 shadow-lg">
              <!-- Simulated timeline -->
              <div class="space-y-4">
                <div class="flex items-center gap-3 p-3 rounded-xl bg-white border border-gray-100">
                  <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center text-lg">✅</div>
                  <div class="flex-1">
                    <div class="text-sm font-semibold text-gray-900">First steps achieved!</div>
                    <div class="text-xs text-gray-500">Parent observation · 12 months</div>
                  </div>
                  <span class="text-xs text-green-600 font-medium">On track</span>
                </div>
                <div class="flex items-center gap-3 p-3 rounded-xl bg-white border border-gray-100">
                  <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-lg">🏥</div>
                  <div class="flex-1">
                    <div class="text-sm font-semibold text-gray-900">SKIDS School Screening</div>
                    <div class="text-xs text-gray-500">Vision · Hearing · Dental · Neuro</div>
                  </div>
                  <span class="text-xs text-blue-600 font-medium">Auto-imported</span>
                </div>
                <div class="flex items-center gap-3 p-3 rounded-xl bg-white border border-gray-100">
                  <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center text-lg">📄</div>
                  <div class="flex-1">
                    <div class="text-sm font-semibold text-gray-900">Pediatrician Visit Report</div>
                    <div class="text-xs text-gray-500">Uploaded PDF · AI extracted</div>
                  </div>
                  <span class="text-xs text-purple-600 font-medium">Analyzed</span>
                </div>
                <div class="flex items-center gap-3 p-3 rounded-xl bg-white border border-gray-100">
                  <div class="w-10 h-10 rounded-full bg-yellow-100 flex items-center justify-center text-lg">📈</div>
                  <div class="flex-1">
                    <div class="text-sm font-semibold text-gray-900">AI Health Summary</div>
                    <div class="text-xs text-gray-500">All data superimposed · trend analysis</div>
                  </div>
                  <span class="text-xs text-gray-600 font-medium">Updated today</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- D2C Services -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <span class="text-sm font-semibold text-orange-600 uppercase tracking-wider">Digital Health Services</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold">Medical-grade care, delivered digitally</h2>
          <p class="mt-4 text-gray-500 text-lg">
            Evidence-based interventions personalized to your child's journey. Nutrition, behavioral health, sleep, and more — from your phone.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {d2cServices.map((service) => (
            <div class="card-hover p-6 rounded-2xl bg-white border border-gray-100 shadow-sm">
              <div class="flex items-center justify-between mb-4">
                <span class="text-3xl">{service.icon}</span>
                <span class="text-[10px] font-semibold px-2.5 py-1 rounded-full bg-gray-100 text-gray-600 uppercase tracking-wider">
                  {service.badge}
                </span>
              </div>
              <h3 class="text-base font-display font-bold text-gray-900">{service.name}</h3>
              <p class="mt-2 text-sm text-gray-500 leading-relaxed">{service.desc}</p>
              <a href="/services" class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-green-600 hover:text-green-700">
                Learn more
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dr. SKIDS Chatbot Teaser -->
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-green-500 to-emerald-600 text-white text-3xl mb-6 shadow-lg shadow-green-500/20">
          🩺
        </div>
        <h2 class="text-3xl sm:text-4xl font-display font-bold">
          Meet Dr. SKIDS — your 24/7 health companion
        </h2>
        <p class="mt-4 text-gray-500 text-lg max-w-2xl mx-auto leading-relaxed">
          Ask anything about your child's health. Powered by expert knowledge from pediatricians, nutritionists, and child development specialists. Personalized to your child's age and profile.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          {[
            'My 3-year-old isn\'t talking yet',
            'Best foods for brain development',
            'Is my child\'s height normal?',
            'Screen time guidelines',
          ].map((q) => (
            <span class="px-4 py-2 rounded-full bg-gray-100 text-sm text-gray-600 border border-gray-200">
              "{q}"
            </span>
          ))}
        </div>
        <div class="mt-10">
          <a href="/dashboard" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-2xl bg-gradient-to-r from-green-600 to-emerald-600 text-white font-semibold text-base hover:from-green-700 hover:to-emerald-700 transition-all shadow-lg shadow-green-500/20">
            Start a Conversation
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- H.A.B.I.T.S -->
    <section class="py-20 bg-gradient-to-br from-green-50 via-emerald-50 to-teal-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <span class="text-sm font-semibold text-teal-600 uppercase tracking-wider">Daily Healthy Habits</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold">Build lifelong H.A.B.I.T.S</h2>
          <p class="mt-4 text-gray-500 text-lg">
            The SKIDS 6-step framework for raising healthy, resilient children. Track daily, build streaks, see the difference.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {[
            { letter: 'H', name: 'Healthy Eating', desc: 'Rainbow plate, brain foods, mindful nutrition', color: 'bg-green-500' },
            { letter: 'A', name: 'Active Movement', desc: 'Physical play that grows the brain', color: 'bg-blue-500' },
            { letter: 'B', name: 'Balanced Stress', desc: 'Resilience building, not stress avoidance', color: 'bg-purple-500' },
            { letter: 'I', name: 'Inner Coaching', desc: 'Growth mindset, positive self-talk', color: 'bg-pink-500' },
            { letter: 'T', name: 'Timekeepers', desc: 'Circadian rhythm, routine mastery', color: 'bg-orange-500' },
            { letter: 'S', name: 'Sufficient Sleep', desc: 'The brain\'s nightly recharge cycle', color: 'bg-indigo-500' },
          ].map((habit) => (
            <div class="card-hover flex items-start gap-4 p-5 rounded-2xl bg-white/80 backdrop-blur border border-white/50 shadow-sm">
              <div class={`w-10 h-10 rounded-xl ${habit.color} flex items-center justify-center text-white font-display font-bold text-lg flex-shrink-0`}>
                {habit.letter}
              </div>
              <div>
                <h3 class="font-display font-bold text-gray-900">{habit.name}</h3>
                <p class="mt-1 text-sm text-gray-500">{habit.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Latest Blog -->
    {blogs.length > 0 && (
      <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between mb-12">
            <div>
              <span class="text-sm font-semibold text-green-600 uppercase tracking-wider">Latest Insights</span>
              <h2 class="mt-2 text-3xl font-display font-bold">Today's parenting wisdom</h2>
            </div>
            <a href="/blog" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-gray-600 hover:text-gray-900">
              View all articles
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {blogs.map((blog: any) => (
              <a href={`/blog/${blog.slug || blog.id}`} class="group card-hover block rounded-2xl overflow-hidden bg-white border border-gray-100 shadow-sm">
                {blog.image && (
                  <div class="aspect-[16/9] overflow-hidden bg-gray-100">
                    <img
                      src={blog.image}
                      alt={blog.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-5">
                  <h3 class="text-base font-display font-bold text-gray-900 group-hover:text-green-600 transition-colors line-clamp-2">
                    {blog.title}
                  </h3>
                  {blog.description && (
                    <p class="mt-2 text-sm text-gray-500 line-clamp-2">{blog.description}</p>
                  )}
                </div>
              </a>
            ))}
          </div>

          <div class="mt-10 text-center sm:hidden">
            <a href="/blog" class="inline-flex items-center gap-2 text-sm font-semibold text-green-600">
              View all articles
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
