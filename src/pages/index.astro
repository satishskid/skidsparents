---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/common/Navbar.astro'
import Footer from '@/components/common/Footer.astro'
import MobileTabBar from '@/components/common/MobileTabBar.astro'
import ChatWidget from '@/components/chat/ChatWidget'
import OnboardingGateWrapper from '@/components/auth/OnboardingGateWrapper'
export const prerender = false

let blogs: any[] = []
try {
  const res = await fetch('https://9vhd0onw23.execute-api.ap-south-1.amazonaws.com/published-blogs')
  if (res.ok) {
    blogs = (await res.json()) as any[]
    blogs.sort((a: any, b: any) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
  }
} catch {}

const heroBlog = blogs[0] || null
const secondaryBlogs = blogs.slice(1, 5)
const heroDate = heroBlog?.createdAt
  ? new Date(heroBlog.createdAt).toLocaleDateString('en-IN', { month: 'long', day: 'numeric' })
  : ''

const categoryColors: Record<string, string> = {
  'Mental Health': 'bg-purple-100 text-purple-700',
  'Parental Guidance': 'bg-pink-100 text-pink-700',
  'Physical Health': 'bg-green-100 text-green-700',
  'Nutrition & Diet': 'bg-orange-100 text-orange-700',
  'Kids Vision': 'bg-amber-100 text-amber-700',
  'Wellness': 'bg-teal-100 text-teal-700',
  'Child Development': 'bg-blue-100 text-blue-700',
}
---

<BaseLayout
  title="SKIDS Parent"
  description="Where parents and pediatricians care together. Daily health insights, developmental guidance, and the pediatric intelligence your child deserves."
>
  <Navbar />
  <main class="overflow-hidden">
    <OnboardingGateWrapper client:load />

    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 1 — HERO: Daily content magazine
         The site opens like a living health journal, not a product.
         ═══════════════════════════════════════════════════════════════ -->
    <section class="bg-white pt-4 pb-8 sm:pb-12">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-10">
        <p class="text-xs font-semibold text-green-600 uppercase tracking-wider mb-4">Today on SKIDS</p>

        {heroBlog ? (
          <div class="md:grid md:grid-cols-3 md:gap-5">
            <!-- Lead story -->
            <a href={`/blog/${heroBlog.blogId}`} class="md:col-span-2 md:row-span-3 group block">
              <div class="relative aspect-[4/3] sm:aspect-[16/10] md:aspect-[4/3] rounded-2xl overflow-hidden mb-4 md:mb-0">
                <img
                  src={heroBlog.thumbnail}
                  alt={heroBlog.title}
                  class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                  loading="eager"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
                <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-8">
                  <span class={`inline-flex text-[10px] font-semibold px-2.5 py-0.5 rounded-full uppercase tracking-wider mb-3 ${categoryColors[heroBlog.category] || 'bg-white/20 text-white'}`}>
                    {heroBlog.category || 'Health'}
                  </span>
                  <h2 class="text-xl sm:text-2xl lg:text-3xl font-display font-extrabold text-white leading-tight mb-2 drop-shadow-lg">
                    {heroBlog.title}
                  </h2>
                  <p class="text-white/60 text-sm">{heroBlog.author || 'SKIDS'} &middot; {heroDate}</p>
                </div>
              </div>
            </a>

            <!-- Secondary stories (desktop: stacked right, mobile: horizontal scroll) -->
            <div class="hidden md:flex md:flex-col md:gap-4">
              {secondaryBlogs.map((blog: any) => (
                <a href={`/blog/${blog.blogId}`} class="group flex gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors">
                  <div class="w-20 h-16 rounded-lg overflow-hidden flex-shrink-0">
                    <img src={blog.thumbnail} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" />
                  </div>
                  <div class="flex-1 min-w-0">
                    <span class={`text-[9px] font-semibold uppercase tracking-wider ${(categoryColors[blog.category] || 'text-gray-500').split(' ').pop()}`}>
                      {blog.category}
                    </span>
                    <h3 class="text-sm font-semibold text-gray-900 leading-snug line-clamp-2 mt-0.5">{blog.title}</h3>
                  </div>
                </a>
              ))}
              <a href="/blog" class="text-sm font-medium text-green-600 hover:text-green-700 px-3 mt-1 inline-flex items-center gap-1">
                All articles <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>

            <!-- Mobile: horizontal scroll row -->
            <div class="md:hidden flex gap-3 overflow-x-auto snap-x snap-mandatory no-scrollbar -mx-4 px-4 mt-4 pb-2">
              {secondaryBlogs.map((blog: any) => (
                <a href={`/blog/${blog.blogId}`} class="snap-start flex-shrink-0 w-[60vw] group">
                  <div class="aspect-[16/10] rounded-xl overflow-hidden mb-2">
                    <img src={blog.thumbnail} alt="" class="w-full h-full object-cover" loading="lazy" />
                  </div>
                  <span class={`text-[9px] font-semibold uppercase tracking-wider ${(categoryColors[blog.category] || 'text-gray-500').split(' ').pop()}`}>
                    {blog.category}
                  </span>
                  <h3 class="text-sm font-semibold text-gray-900 leading-snug line-clamp-2 mt-0.5">{blog.title}</h3>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <div class="text-center py-20">
            <h2 class="text-2xl font-display font-bold text-gray-900 mb-3">Your child's health, every day.</h2>
            <p class="text-gray-500 mb-6">Evidence-based articles on child health, development, and parenting.</p>
            <a href="/blog" class="text-green-600 font-semibold text-sm hover:text-green-700">Browse articles &rarr;</a>
          </div>
        )}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 2 — EMOTIONAL HOOK: The quiet signals
         Recognition, not fear. The parent reads this and thinks "that's me."
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-28 section-warm">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-10">
        <div class="max-w-3xl">
          <h2 class="text-3xl sm:text-4xl font-display font-bold text-gray-900 leading-tight mb-4">
            Every childhood has quiet signals.
          </h2>
          <p class="text-lg sm:text-xl text-gray-500 italic mb-14">
            You're not paranoid. You're paying attention. And that matters more than you know.
          </p>
        </div>

        <div class="grid sm:grid-cols-3 gap-6">
          <div class="bg-white rounded-2xl p-6 border border-gray-100">
            <div class="text-4xl font-display font-extrabold text-green-600 mb-3">80%</div>
            <p class="text-sm text-gray-500 leading-relaxed">
              of brain development happens before age 3.
              Most developmental screenings don't happen until after age 5.
            </p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-gray-100">
            <div class="text-4xl font-display font-extrabold text-amber-600 mb-3">4 in 10</div>
            <p class="text-sm text-gray-500 leading-relaxed">
              Indian children are anemic. A child can look perfectly healthy
              and be missing the iron their brain needs to develop.
            </p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-gray-100">
            <div class="text-4xl font-display font-extrabold text-purple-600 mb-3">1 in 4</div>
            <p class="text-sm text-gray-500 leading-relaxed">
              children have an undetected vision problem.
              The signs often look like "not paying attention" or "being shy."
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 3 — CO-NURTURING: The 6,000 hours insight
         Reframe parent as expert observer. Introduce SKIDS concept.
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-28 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-10">
        <div class="max-w-3xl mb-14">
          <p class="text-sm text-gray-400 mb-4">A different kind of care</p>
          <h2 class="text-3xl sm:text-4xl font-display font-bold text-gray-900 leading-tight mb-5">
            Your pediatrician sees your child 6 hours a year.<br class="hidden sm:block" />
            You see them 6,000.
          </h2>
          <p class="text-lg text-gray-500 leading-relaxed">
            You notice how they hold a crayon, what makes them go quiet, whether they're
            eating less this week. That isn't worry — that's intelligence.
            SKIDS turns what you already see into something your doctor can act on.
          </p>
        </div>

        <div class="grid sm:grid-cols-3 gap-5">
          <div class="rounded-2xl p-6 border border-gray-100 bg-white">
            <div class="text-2xl mb-3">You</div>
            <div class="text-3xl font-display font-extrabold text-gray-900 mb-2">6,000 hrs</div>
            <p class="text-sm text-gray-500 leading-relaxed">
              You see the daily patterns — sleep, appetite, mood, energy.
              The things no test can capture. The things only a parent knows.
            </p>
          </div>
          <div class="rounded-2xl p-6 border border-gray-100 bg-white">
            <div class="text-2xl mb-3">Your pediatrician</div>
            <div class="text-3xl font-display font-extrabold text-gray-900 mb-2">6 hrs</div>
            <p class="text-sm text-gray-500 leading-relaxed">
              Clinical training, diagnostic instinct, treatment expertise.
              Deep knowledge in short windows. Every minute counts.
            </p>
          </div>
          <div class="rounded-2xl p-6 border border-green-200 bg-green-50">
            <div class="text-2xl mb-3">SKIDS</div>
            <div class="text-3xl font-display font-extrabold text-green-700 mb-2">The bridge</div>
            <p class="text-sm text-gray-600 leading-relaxed">
              Connects your daily observations to your doctor's clinical picture.
              So nothing falls between the cracks. So no signal goes unread.
            </p>
          </div>
        </div>

        <p class="text-center mt-10 text-xl font-display font-semibold text-gray-900">
          We call this co-nurturing.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 4 — WHAT HAPPENS: The experience in parent words
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-28 section-warm">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-10">
        <p class="text-sm text-gray-400 mb-4">How it works</p>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-gray-900 leading-tight mb-16">
          What happens when you bring your child to SKIDS.
        </h2>

        <div class="space-y-12 sm:space-y-0 sm:grid sm:grid-cols-3 sm:gap-12">
          <div class="relative">
            <div class="text-7xl font-display font-extrabold text-gray-200/60 absolute -top-4 -left-1 select-none">1</div>
            <div class="relative pt-12">
              <h3 class="text-lg font-bold text-gray-900 mb-3">Your child gets a health picture</h3>
              <p class="text-gray-500 leading-relaxed">
                A 30-minute screening across vision, hearing, development, nutrition, and more.
                Not a test with pass or fail — a picture of where your child is right now.
              </p>
            </div>
          </div>

          <div class="relative">
            <div class="text-7xl font-display font-extrabold text-gray-200/60 absolute -top-4 -left-1 select-none">2</div>
            <div class="relative pt-12">
              <h3 class="text-lg font-bold text-gray-900 mb-3">You see what matters</h3>
              <p class="text-gray-500 leading-relaxed">
                What's thriving, what to keep an eye on, what needs a conversation with
                your doctor. Clear, simple, personal to your child — not generic advice.
              </p>
            </div>
          </div>

          <div class="relative">
            <div class="text-7xl font-display font-extrabold text-gray-200/60 absolute -top-4 -left-1 select-none">3</div>
            <div class="relative pt-12">
              <h3 class="text-lg font-bold text-gray-900 mb-3">You and your doctor act together</h3>
              <p class="text-gray-500 leading-relaxed">
                Your pediatrician sees the full picture. You get daily guidance that fits your
                child. Not a prescription and a prayer — a plan that grows with them.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 5 — CREDIBILITY: Woven, not dumped
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-24 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-10 text-center">
        <p class="text-2xl sm:text-3xl font-display font-bold text-gray-900 leading-snug">
          SKIDS has screened <span class="text-green-600">15,000 children</span>
          across <span class="text-green-600">150+ health conditions</span>.
          Every day, families and pediatricians use it to catch what routine checkups miss.
        </p>
        <p class="mt-6 text-base text-gray-400 max-w-xl mx-auto">
          Born from a multi-specialty pediatric screening program in Hyderabad.
          Now a platform that turns one moment of screening into a lifetime of informed care.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 6 — FOR PEDIATRICIANS: Brief, professional
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-20 section-warm border-t border-gray-200/60">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-10">
        <div class="md:grid md:grid-cols-2 md:gap-14 items-center">
          <div>
            <p class="text-sm font-semibold text-blue-600 tracking-widest uppercase mb-4">For pediatricians</p>
            <h2 class="text-2xl sm:text-3xl font-display font-bold text-gray-900 leading-tight mb-5">
              Your patients, between visits.
            </h2>
            <p class="text-gray-500 leading-relaxed mb-6">
              A clinical dashboard with every patient's health record, parent observations,
              growth trajectories, and flagged concerns — so you walk into every
              appointment already informed.
            </p>
            <a href="/ped/register" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gray-900 text-white font-semibold text-sm hover:bg-gray-800 transition-colors">
              See how it works for clinicians
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>

          <div class="mt-10 md:mt-0">
            <div class="bg-white rounded-2xl border border-gray-200/80 p-5 space-y-3">
              <div class="flex items-center gap-3 pb-3 border-b border-gray-100">
                <div class="w-7 h-7 rounded-lg bg-blue-100 flex items-center justify-center">
                  <svg class="w-3.5 h-3.5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                </div>
                <span class="text-sm font-semibold text-gray-900">Doctor Dashboard</span>
              </div>
              <div class="flex items-start gap-3 py-1.5">
                <div class="w-1.5 h-1.5 rounded-full bg-green-500 mt-1.5 shrink-0"></div>
                <div>
                  <div class="text-sm font-medium text-gray-900">Daily patient brief</div>
                  <div class="text-xs text-gray-400">Summary of your panel's health changes</div>
                </div>
              </div>
              <div class="flex items-start gap-3 py-1.5">
                <div class="w-1.5 h-1.5 rounded-full bg-amber-500 mt-1.5 shrink-0"></div>
                <div>
                  <div class="text-sm font-medium text-gray-900">Flagged concerns</div>
                  <div class="text-xs text-gray-400">Conditions needing attention, ranked by urgency</div>
                </div>
              </div>
              <div class="flex items-start gap-3 py-1.5">
                <div class="w-1.5 h-1.5 rounded-full bg-blue-500 mt-1.5 shrink-0"></div>
                <div>
                  <div class="text-sm font-medium text-gray-900">Intervention tracking</div>
                  <div class="text-xs text-gray-400">Compliance, streaks, and escalation alerts</div>
                </div>
              </div>
              <div class="flex items-start gap-3 py-1.5">
                <div class="w-1.5 h-1.5 rounded-full bg-purple-500 mt-1.5 shrink-0"></div>
                <div>
                  <div class="text-sm font-medium text-gray-900">Clinical protocols</div>
                  <div class="text-xs text-gray-400">Evidence-based, region-aware pathways</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 7 — CTA: Warm, human, inviting
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-28 bg-gradient-to-br from-green-50 via-emerald-50/50 to-teal-50/30">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-10 text-center">
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-gray-900 leading-tight mb-4">
          See what your child's health<br class="hidden sm:block" />
          is telling you.
        </h2>
        <p class="text-lg text-gray-500 mb-8">
          It takes 5 minutes. It's free. And it might change everything.
        </p>
        <a href="/login" class="inline-flex px-8 py-4 rounded-xl bg-green-600 text-white font-semibold text-base hover:bg-green-500 transition-colors shadow-lg shadow-green-600/20">
          Start your child's health picture
        </a>
      </div>
    </section>

    <ChatWidget client:load />
  </main>
  <Footer />
  <MobileTabBar />
</BaseLayout>
