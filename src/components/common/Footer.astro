---
const year = new Date().getFullYear()

const footerLinks = {
  'For Parents': [
    { href: '/blog', label: 'Health Blog' },
    { href: '/discover', label: 'Organ Discovery' },
    { href: '/services', label: 'Services' },
    { href: '/about', label: 'Why SKIDS?' },
  ],
  'Resources': [
    { href: '/discover/brain', label: 'Brain Development' },
    { href: '/discover/eyes', label: 'Vision Health' },
    { href: '/discover/emotions', label: 'Emotional Health' },
    { href: '/blog?category=nutrition', label: 'Nutrition Tips' },
  ],
  'Company': [
    { href: 'https://skids.clinic', label: 'SKIDS Clinic' },
    { href: 'https://medium.com/@skids_health', label: 'Medium Blog' },
    { href: '/privacy', label: 'Privacy Policy' },
    { href: '/terms', label: 'Terms of Service' },
  ],
}
---

<footer class="bg-gray-50 border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2.5">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center text-white font-bold text-sm">
            S
          </div>
          <div class="flex flex-col">
            <span class="text-lg font-display font-bold leading-tight">SKIDS</span>
            <span class="text-[10px] font-medium text-gray-400 leading-none tracking-wider uppercase">Parent</span>
          </div>
        </a>
        <p class="mt-4 text-sm text-gray-500 leading-relaxed max-w-xs">
          Raising smart, healthy S-Kids with evidence-based care. Physical. Mental. Social.
        </p>
        <div class="mt-4 flex items-center gap-1.5">
          <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-green-50 text-green-700 text-[10px] font-medium">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 pulse-dot"></span>
            Evidence-based
          </span>
          <span class="inline-flex px-2 py-1 rounded-full bg-blue-50 text-blue-700 text-[10px] font-medium">
            24/7 AI Support
          </span>
        </div>
      </div>

      <!-- Links -->
      {Object.entries(footerLinks).map(([title, links]) => (
        <div>
          <h3 class="text-xs font-semibold text-gray-900 uppercase tracking-wider">{title}</h3>
          <ul class="mt-4 space-y-2.5">
            {links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
                  {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-400">
        &copy; {year} SKIDS Health Technologies. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://skids.clinic/feed" target="_blank" rel="noopener" class="text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36zM4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44zm0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/></svg>
        </a>
        <a href="https://medium.com/@skids_health" target="_blank" rel="noopener" class="text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
