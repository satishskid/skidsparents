---
import NotificationBell from '@/components/common/NotificationBell'
import NavbarUser from '@/components/auth/NavbarUser'

const currentPath = Astro.url.pathname

const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/discover', label: 'Discover' },
  { href: '/timeline', label: 'Timeline' },
  { href: '/interventions', label: 'Interventions' },
]

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/'
  return currentPath.startsWith(href)
}
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-lg border-b border-gray-100/80">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center text-white font-bold text-xs shadow-sm group-hover:shadow-md transition-shadow">
          S
        </div>
        <div class="flex flex-col">
          <span class="text-base font-display font-bold leading-tight text-gray-900">SKIDS</span>
          <span class="text-[9px] font-medium text-gray-400 leading-none tracking-wider uppercase">Parent</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3.5 py-1.5 rounded-lg text-sm font-medium transition-colors',
              isActive(link.href)
                ? 'bg-green-50 text-green-700'
                : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right side: Notification Bell only (mobile uses bottom tabs) -->
      <div class="flex items-center gap-1.5">
        <NotificationBell client:load />

        <!-- User avatar — desktop only -->
        <div class="hidden md:flex items-center">
          <NavbarUser client:load />
        </div>
      </div>
    </div>
  </nav>
</header>
