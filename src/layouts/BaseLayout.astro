---
import { SOCIAL, BRAND } from '@/lib/config/social'

interface Props {
  title: string
  description?: string
  ogImage?: string
  ogType?: string
  canonical?: string
  noIndex?: boolean
  /** For blog pages — article structured data */
  article?: {
    headline: string
    author: string
    datePublished: string
    dateModified?: string
    image: string
    category: string
    description: string
  }
}

const {
  title,
  description = 'SKIDS Parent — The place where today\'s parents come to raise smart, healthy S-Kids. Evidence-based child health, developmental tracking, and personalized care.',
  ogImage = '/og/default.png',
  ogType = 'website',
  canonical,
  noIndex = false,
  article,
} = Astro.props

const siteUrl = BRAND.siteUrl
const fullTitle = title === 'SKIDS Parent' ? title : `${title} | SKIDS Parent`
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`
const canonicalUrl = canonical || Astro.url.href
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="SKIDS Parent" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SOCIAL.twitterHandle} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#16a34a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="SKIDS Parent" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data — Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": BRAND.name,
      "legalName": BRAND.legalName,
      "url": siteUrl,
      "logo": `${siteUrl}/icons/icon-512.png`,
      "description": BRAND.tagline,
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": SOCIAL.whatsapp,
        "contactType": "customer service",
        "availableLanguage": ["English", "Hindi"]
      },
      "sameAs": [
        SOCIAL.instagram,
        SOCIAL.twitter,
        SOCIAL.facebook,
        SOCIAL.youtube,
        SOCIAL.linkedin,
        SOCIAL.medium,
        SOCIAL.clinic
      ]
    })} />

    {/* Structured Data — Article (for blog pages) */}
    {article && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": article.headline,
        "image": article.image,
        "author": {
          "@type": "Person",
          "name": article.author
        },
        "publisher": {
          "@type": "Organization",
          "name": BRAND.name,
          "logo": {
            "@type": "ImageObject",
            "url": `${siteUrl}/icons/icon-512.png`
          }
        },
        "datePublished": article.datePublished,
        "dateModified": article.dateModified || article.datePublished,
        "description": article.description,
        "articleSection": article.category,
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalUrl
        }
      })} />
    )}

    <!-- Google Analytics 4 (brand=skids namespace — STRICT COMPLIANCE) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-T5E4SKLMG3"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-T5E4SKLMG3', {
        brand: 'skids',
        center: 'online',
        send_page_view: true
      });
    </script>

    <!-- Meta Pixel (brand=skids namespace — STRICT COMPLIANCE) -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1244835147469135');
      fbq('track', 'PageView', { brand: 'skids' });
    </script>
    <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=1244835147469135&ev=PageView&noscript=1" /></noscript>

    <!-- Cloudflare Web Analytics (brand=skids) -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "309a8c94a071430fbbec01c920007bda"}'></script>

    <!--
      SKIDS Analytics SDK (brand=skids STRICT COMPLIANCE)
      ====================================================
      Rules enforced:
      1. brand=skids on EVERY event — no exceptions
      2. GA4 params: brand, center, funnel_stage, asset_code
      3. Meta Pixel custom_data: brand: "skids"
      4. UTM campaign must start with "skids_" — non-compliant URLs flagged
      5. Lead capture requires brand field — never blank
    -->
    <script is:inline>
      (function() {
        var BRAND = 'skids';

        // ─── UTM Parser + Validator ───
        function parseUTM() {
          var p = new URLSearchParams(window.location.search);
          var campaign = p.get('utm_campaign');
          if (campaign && campaign.indexOf('skids_') !== 0) {
            console.warn('[SKIDS] NON-COMPLIANT UTM: campaign="' + campaign +
              '" must start with "skids_". Format: skids_<service>_<city>_<offer>_<month>');
          }
          return {
            utm_source: p.get('utm_source') || undefined,
            utm_medium: p.get('utm_medium') || undefined,
            utm_campaign: campaign || undefined,
            utm_content: p.get('utm_content') || undefined,
            asset: p.get('asset') || undefined
          };
        }

        // Store UTM for session
        var utm = parseUTM();
        if (utm.utm_source) {
          try { sessionStorage.setItem('skids_utm', JSON.stringify(utm)); } catch(e) {}
        }

        // ─── skidsTrack: Unified event tracking (GA4 + Meta + console) ───
        // MANDATORY params: brand (auto-injected), funnel_stage
        // OPTIONAL params: center, asset_code, + any custom params
        window.skidsTrack = function(eventName, params) {
          var p = Object.assign({
            brand: BRAND,
            center: 'online'
          }, params || {});

          // Warn if funnel_stage missing
          if (!p.funnel_stage) {
            console.warn('[SKIDS] Event "' + eventName + '" missing funnel_stage. ' +
              'Required: awareness|interest|consideration|intent|conversion|retention');
          }

          // Merge UTM if available
          var savedUTM;
          try { savedUTM = JSON.parse(sessionStorage.getItem('skids_utm') || '{}'); } catch(e) { savedUTM = {}; }
          if (savedUTM.utm_source) {
            p.utm_source = p.utm_source || savedUTM.utm_source;
            p.utm_medium = p.utm_medium || savedUTM.utm_medium;
            p.utm_campaign = p.utm_campaign || savedUTM.utm_campaign;
            p.asset_code = p.asset_code || savedUTM.asset;
          }

          // Fire to GA4
          if (typeof gtag === 'function') {
            gtag('event', eventName, p);
          }

          // Fire to Meta Pixel (brand in custom_data)
          if (typeof fbq === 'function') {
            fbq('trackCustom', eventName, p);
          }
        };

        // ─── skidsCaptureLead: Lead capture with brand=skids enforced ───
        // For Neodove CRM integration (server-side push)
        window.skidsCaptureLead = function(leadData) {
          var lead = Object.assign({
            brand: BRAND,
            center: 'online',
            created_at: new Date().toISOString()
          }, leadData);

          // Validate required fields
          var required = ['brand', 'name', 'phone', 'source', 'funnel_stage'];
          var missing = required.filter(function(f) { return !lead[f]; });
          if (missing.length > 0) {
            console.error('[SKIDS] Lead capture BLOCKED — missing required fields: ' + missing.join(', '));
            return null;
          }

          // Merge UTM
          var savedUTM;
          try { savedUTM = JSON.parse(sessionStorage.getItem('skids_utm') || '{}'); } catch(e) { savedUTM = {}; }
          lead.utm_source = lead.source || savedUTM.utm_source || 'organic';
          lead.utm_campaign = lead.campaign || savedUTM.utm_campaign;

          // Fire conversion event
          window.skidsTrack('lead_capture', {
            funnel_stage: lead.funnel_stage,
            asset_code: lead.asset_code,
            center: lead.center
          });

          // Post to server API for Neodove + BHASH
          fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(lead)
          }).catch(function(err) {
            console.error('[SKIDS] Lead API error:', err);
          });

          return lead;
        };

        // ─── Auto-track page context ───
        window.skidsTrack('page_view', {
          funnel_stage: (function() {
            var path = window.location.pathname;
            if (path === '/') return 'awareness';
            if (path.indexOf('/blog') === 0) return 'awareness';
            if (path.indexOf('/discover') === 0) return 'interest';
            if (path.indexOf('/timeline') === 0) return 'consideration';
            if (path.indexOf('/services') === 0) return 'intent';
            if (path.indexOf('/me') === 0) return 'retention';
            return 'awareness';
          })(),
          asset_code: window.location.pathname.replace(/\//g, '_').replace(/^_|_$/g, '') || 'home',
          page_path: window.location.pathname
        });

      })();
    </script>

    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="min-h-screen bg-white text-gray-900 font-sans antialiased">
    <slot />
  </body>
</html>
